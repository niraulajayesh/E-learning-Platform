@{
    ViewData["Title"] = "Create Account";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account — LearnHub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #0f0a1e 0%, #1e1050 60%, #2d1b69 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem 1rem; }
        .auth-card { background: rgba(255,255,255,0.05); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 2.5rem; width: 100%; max-width: 480px; color: #fff; }
        .brand { font-family: 'Outfit', sans-serif; font-weight: 900; font-size: 1.8rem; background: linear-gradient(135deg, #8b5cf6, #c4b5fd); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; text-decoration: none; }
        .form-control { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); color: #fff; border-radius: 10px; padding: 0.75rem 1rem; }
        .form-control:focus { background: rgba(255,255,255,0.1); border-color: #8b5cf6; box-shadow: 0 0 0 3px rgba(139,92,246,0.25); color: #fff; }
        .form-control::placeholder { color: rgba(255,255,255,0.4); }
        .form-label { color: #d1d5db; font-size: 0.88rem; font-weight: 500; }
        .btn-auth { background: linear-gradient(135deg, #6c2bd9, #8b5cf6); border: none; color: #fff; width: 100%; border-radius: 10px; padding: 0.8rem; font-weight: 700; font-size: 1rem; transition: all 0.25s; }
        .btn-auth:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(108,43,217,0.5); color: #fff; }
        .link-purple { color: #c4b5fd; text-decoration: none; }
        .link-purple:hover { color: #e9d5ff; text-decoration: underline; }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="text-center mb-4">
            <a href="/" class="brand">LearnHub</a>
            <h2 class="mt-3 mb-1" style="font-size:1.5rem;font-weight:700;">Start learning today</h2>
            <p style="color:#9ca3af;font-size:0.9rem;">Join thousands of learners worldwide</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert border-0 rounded-3 mb-3" style="background:rgba(239,68,68,0.15);color:#fca5a5;">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
            </div>
        }

        <form method="post" action="/Auth/Register">
            @Html.AntiForgeryToken()
            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label">First Name</label>
                    <input type="text" name="firstName" class="form-control" placeholder="John" required />
                </div>
                <div class="col-6">
                    <label class="form-label">Last Name</label>
                    <input type="text" name="lastName" class="form-control" placeholder="Doe" required />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Email Address</label>
                <input type="email" name="email" class="form-control" placeholder="you@example.com" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" placeholder="Min. 8 characters" required minlength="8" />
            </div>
            <div class="mb-4">
                <label class="form-label">Confirm Password</label>
                <input type="password" name="confirmPassword" class="form-control" placeholder="Repeat your password" required />
            </div>
            <p style="font-size:0.78rem;color:#6b7280;margin-bottom:1rem;">By signing up, you agree to our <a href="#" class="link-purple">Terms</a> and <a href="#" class="link-purple">Privacy Policy</a>.</p>
            <button type="submit" class="btn btn-auth">Create Free Account</button>
        </form>

        <p class="text-center mt-4 mb-0" style="font-size:0.9rem;color:#9ca3af;">
            Already have an account? <a href="/Auth/Login" class="link-purple fw-600">Sign in</a>
        </p>
    </div>
</body>
</html>
