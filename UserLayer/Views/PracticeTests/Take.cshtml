@model DataLayer.Entities.PracticeTest
@{
    var questions = Model.ShuffleQuestions ? Model.Questions.OrderBy(_ => Guid.NewGuid()).ToList() : Model.Questions.OrderBy(q => q.Order).ToList();
}
<section class="premium-hero py-4"><div class="container"><span class="section-badge"><i class="bi bi-stopwatch"></i> @Model.Category?.Name</span><h1 class="section-title text-white mt-3 mb-2">@Model.Title</h1><p style="color:#cbd5e1">@(Model.IsTimed ? $"Timed: {Model.TimeLimitMinutes} minutes" : "Untimed practice") · @questions.Count questions · Passing score @Model.PassingScorePercent%</p></div></section>
<div class="container py-5"><form method="post" action="/PracticeTests/Submit/@Model.Id" id="testForm">@Html.AntiForgeryToken()<div class="d-flex justify-content-between align-items-center mb-3"><a href="/PracticeTests" class="text-decoration-none fw-bold"><i class="bi bi-arrow-left"></i> Practice tests</a>@if(Model.IsTimed){<span class="course-count-chip"><i class="bi bi-stopwatch"></i><span id="timer">@Model.TimeLimitMinutes:00</span></span>}</div><div class="d-grid gap-4">@foreach(var q in questions){var opts = new[]{("A",q.OptionA),("B",q.OptionB),("C",q.OptionC),("D",q.OptionD),("E",q.OptionE),("F",q.OptionF)}.Where(o=>!string.IsNullOrWhiteSpace(o.Item2)); if(Model.ShuffleAnswers){opts=opts.OrderBy(_=>Guid.NewGuid()).ToList();}<div class="dashboard-card"><div class="fw-bold mb-3">@q.Order. @q.Text</div>@foreach(var opt in opts){<label class="d-flex gap-2 align-items-start border rounded p-3 mb-2"><input type="radio" name="answers[@q.Id]" value="@opt.Item1" class="form-check-input mt-1" /><span><strong>@opt.Item1.</strong> @opt.Item2</span></label>}</div>}</div><button class="btn-primary-custom mt-4" style="border:none;">Submit Test</button></form></div>
@if(Model.IsTimed){<script>let s=@((Model.TimeLimitMinutes ?? 0)*60);const t=document.getElementById('timer');const f=document.getElementById('testForm');setInterval(()=>{if(s<=0){f.submit();return;}s--;const m=Math.floor(s/60),r=String(s%60).padStart(2,'0');t.textContent=`${m}:${r}`;},1000);</script>}
