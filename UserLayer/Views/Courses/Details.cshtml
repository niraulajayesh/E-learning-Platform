@model DataLayer.Entities.Course
@{
    var isEnrolled = (bool)(ViewBag.IsEnrolled ?? false);
    var enrollment = ViewBag.Enrollment as DataLayer.Entities.Enrollment;
    var lessons = ViewBag.Lessons as List<DataLayer.Entities.Lesson> ?? new();
    var completedLessonIds = ViewBag.CompletedLessonIds as IReadOnlySet<Guid> ?? new HashSet<Guid>();
    var firstLesson = ViewBag.FirstLesson as DataLayer.Entities.Lesson;
    var displayPrice = Model.DiscountedPrice ?? Model.Price;
    var levelLabel = Model.Level switch { SharedLayer.Enums.CourseLevel.Beginner => "Beginner", SharedLayer.Enums.CourseLevel.Intermediate => "Intermediate", SharedLayer.Enums.CourseLevel.Advanced => "Advanced", _ => "All Levels" };
    var whatToLearn = (Model.WhatYouWillLearn ?? "").Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    var requirements = (Model.Requirements ?? "").Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    var targetAudience = (Model.TargetAudience ?? "").Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    var duration = $"{Model.TotalDurationMinutes / 60}h {Model.TotalDurationMinutes % 60}m";
}

<section class="premium-hero" style="padding:3.3rem 0 3rem;">
    <div class="container">
        <div class="row gy-4 align-items-start">
            <div class="col-lg-7">
                <nav class="mb-3" style="font-size:.86rem;color:#cbd5e1;">
                    <a href="/" class="text-decoration-none" style="color:#cbd5e1;">Home</a><span class="mx-2">/</span><a href="/Courses" class="text-decoration-none" style="color:#cbd5e1;">Courses</a>
                    @if (Model.Category != null)
                    {
                        <span class="mx-2">/</span><a href="/Categories/Details/@Model.CategoryId" class="text-decoration-none" style="color:#cbd5e1;">@Model.Category.Name</a>
                    }
                </nav>

                <div class="d-flex gap-2 flex-wrap mb-3">
                    @if (Model.IsBestseller) { <span class="badge rounded-pill" style="background:#fef0c7;color:#b54708;padding:.5rem .75rem;font-weight:900;">Bestseller</span> }
                    @if (Model.IsFeatured) { <span class="badge rounded-pill" style="background:#dbeafe;color:#175cd3;padding:.5rem .75rem;font-weight:900;">Featured</span> }
                    <span class="badge-level badge-all">@levelLabel</span>
                </div>
                <h1 class="text-white" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;line-height:1.04;">@Model.Title</h1>
                <p class="mt-3" style="color:#d0d8e8;font-size:1.05rem;line-height:1.8;max-width:680px;">@Model.ShortDescription</p>

                <div class="d-flex flex-wrap gap-3 align-items-center mt-4" style="color:#cbd5e1;">
                    <span><strong style="color:#fbbf24;">@Model.AverageRating.ToString("0.0")</strong> <span class="rating-stars">@for (var i = 1; i <= 5; i++) { <i class="bi @(i <= (int)Math.Round(Model.AverageRating) ? "bi-star-fill" : "bi-star")"></i> }</span> (@Model.TotalReviews)</span>
                    <span><i class="bi bi-people me-1"></i>@Model.TotalEnrollments students</span>
                    <span><i class="bi bi-clock me-1"></i>@duration</span>
                    <span><i class="bi bi-globe me-1"></i>@Model.Language</span>
                </div>

                @if (Model.Instructor != null)
                {
                    <p class="mt-3 mb-0" style="color:#cbd5e1;">Created by <a href="/Instructors/Details/@Model.InstructorId" style="color:#67e8f9;text-decoration:none;font-weight:900;">@Model.Instructor.FullName</a></p>
                }
            </div>

            <div class="col-lg-5">
                <aside class="premium-card sticky-top" style="top:94px;padding:1rem;box-shadow:var(--shadow-lg);">
                    @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
                    {
                        <img src="@Model.ThumbnailUrl" alt="@Model.Title" style="width:100%;aspect-ratio:16/9;object-fit:cover;border-radius:12px;" />
                    }
                    else
                    {
                        <div class="course-media-fallback" style="aspect-ratio:16/9;border-radius:12px;"><i class="bi bi-journal-code"></i></div>
                    }

                    <div class="p-2 pt-3">
                        <div class="mb-3">
                            @if (displayPrice == 0)
                            {
                                <span class="course-price course-price-free" style="font-size:2rem;">Free</span>
                            }
                            else
                            {
                                <span class="course-price" style="font-size:2rem;">$@displayPrice.ToString("0.00")</span>
                                @if (Model.DiscountedPrice.HasValue && Model.Price > 0)
                                {
                                    <span class="course-old-price ms-2">$@Model.Price.ToString("0.00")</span>
                                }
                            }
                        </div>

                        @if (isEnrolled)
                        {
                            <div class="text-center mb-3 py-3" style="background:#ecfdf3;border:1px solid #abefc6;border-radius:12px;"><i class="bi bi-check-circle-fill" style="color:var(--success);font-size:1.4rem;"></i><div style="color:#067647;font-weight:900;margin-top:.35rem;">You are enrolled</div></div>
                            @if (firstLesson != null)
                            {
                                <a href="/Lessons/Watch/@firstLesson.Id" class="btn-primary-custom w-100"><i class="bi bi-play-circle-fill"></i> Start learning</a>
                            }
                            else
                            {
                                <a href="/MyCourses" class="btn-primary-custom w-100"><i class="bi bi-play-circle-fill"></i> Go to My Courses</a>
                            }
                        }
                        else if (User.Identity?.IsAuthenticated == true)
                        {
                            <form method="post" action="/Courses/Enroll">@Html.AntiForgeryToken()<input type="hidden" name="courseId" value="@Model.Id" /><button type="submit" class="btn-primary-custom w-100" style="border:none;"><i class="bi bi-lightning-charge-fill"></i>@(displayPrice == 0 ? "Enroll for free" : "Enroll now")</button></form>
                            <form method="post" action="/Wishlist/Add" class="mt-2">@Html.AntiForgeryToken()<input type="hidden" name="courseId" value="@Model.Id" /><button type="submit" class="btn-outline-custom w-100"><i class="bi bi-heart"></i> Save to wishlist</button></form>
                        }
                        else
                        {
                            <a href="/Auth/Login?returnUrl=/Courses/Details/@Model.Id" class="btn-primary-custom w-100"><i class="bi bi-box-arrow-in-right"></i> Sign in to enroll</a>
                        }

                        <div class="mt-4 pt-3" style="border-top:1px solid var(--line);">
                            <h2 style="font-size:1rem;font-weight:900;">This course includes</h2>
                            @foreach (var item in new[] { ($"bi-play-btn-fill", $"{Model.TotalLessons} lessons"), ("bi-clock", duration), ("bi-award", "Certificate of completion"), ("bi-infinity", "Lifetime access") })
                            {
                                <div class="d-flex align-items-center gap-2 mt-2 course-meta"><i class="bi @item.Item1" style="color:var(--brand);"></i>@item.Item2</div>
                            }
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </div>
</section>

<div class="container py-5">
    <div class="row g-4">
        <main class="col-lg-8">
            @if (whatToLearn.Any())
            {
                <section class="dashboard-card mb-4">
                    <h2 style="font-size:1.35rem;font-weight:900;margin-bottom:1.2rem;">What you will learn</h2>
                    <div class="row row-cols-1 row-cols-md-2 g-3">
                        @foreach (var item in whatToLearn)
                        {
                            <div class="col d-flex gap-2"><i class="bi bi-check-circle-fill flex-shrink-0 mt-1" style="color:var(--brand-2);"></i><span style="color:#344054;line-height:1.6;">@item</span></div>
                        }
                    </div>
                </section>
            }

            @if (lessons.Any())
            {
                <section class="dashboard-card mb-4">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                        <h2 style="font-size:1.35rem;font-weight:900;margin:0;">Course curriculum</h2>
                        @if (enrollment != null)
                        {
                            <span class="badge rounded-pill" style="background:#eef3ff;color:var(--brand);padding:.55rem .8rem;">@enrollment.CompletionPercentage.ToString("0")% complete</span>
                        }
                    </div>

                    <div class="d-grid gap-2">
                        @foreach (var lesson in lessons)
                        {
                            var completed = completedLessonIds.Contains(lesson.Id);
                            <div class="d-flex align-items-center justify-content-between gap-3" style="padding:1rem;border:1px solid var(--line);border-radius:12px;background:#fff;">
                                <div class="d-flex align-items-start gap-3">
                                    <span style="width:38px;height:38px;border-radius:11px;display:grid;place-items:center;background:@(completed ? "#dcfae6" : "#eef3ff");color:@(completed ? "#067647" : "var(--brand)");"><i class="bi @(completed ? "bi-check-circle-fill" : lesson.Type == SharedLayer.Enums.LessonType.Video ? "bi-play-circle" : "bi-file-earmark-text")"></i></span>
                                    <div>
                                        <div style="font-weight:900;">@lesson.Title</div>
                                        <div class="course-meta">@lesson.Type · @lesson.DurationMinutes min</div>
                                    </div>
                                </div>
                                @if (isEnrolled)
                                {
                                    <a href="/Lessons/Watch/@lesson.Id" class="btn-outline-custom" style="padding:.45rem .85rem;width:auto;">Open</a>
                                }
                                else if (lesson.IsFreePreview)
                                {
                                    <span class="badge" style="background:#eef3ff;color:var(--brand);">Preview</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-light"><i class="bi bi-lock me-1"></i>Locked</span>
                                }
                            </div>
                        }
                    </div>
                </section>
            }

            @if (requirements.Any())
            {
                <section class="dashboard-card mb-4">
                    <h2 style="font-size:1.25rem;font-weight:900;">Requirements</h2>
                    <ul style="margin:0;padding-left:1.2rem;color:#475467;line-height:2;">@foreach (var req in requirements) { <li>@req</li> }</ul>
                </section>
            }

            @if (targetAudience.Any())
            {
                <section class="dashboard-card mb-4">
                    <h2 style="font-size:1.25rem;font-weight:900;">Who this is for</h2>
                    <ul style="margin:0;padding-left:1.2rem;color:#475467;line-height:2;">@foreach (var audience in targetAudience) { <li>@audience</li> }</ul>
                </section>
            }
        </main>

        <aside class="col-lg-4">
            @if (Model.Instructor != null)
            {
                <section class="dashboard-card"><h2 style="font-size:1.2rem;font-weight:900;margin-bottom:1rem;">Instructor</h2>
                    <div class="d-flex gap-3 align-items-start">
                        @if (!string.IsNullOrEmpty(Model.Instructor.ProfilePictureUrl))
                        {
                            <img src="@Model.Instructor.ProfilePictureUrl" alt="@Model.Instructor.FullName" class="instructor-avatar" style="width:64px;height:64px;" />
                        }
                        else
                        {
                            <div style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--brand),var(--brand-2));display:grid;place-items:center;color:#fff;font-size:1.4rem;font-weight:900;flex-shrink:0;">@Model.Instructor.FullName.Substring(0,1)</div>
                        }
                        <div>
                            <a href="/Instructors/Details/@Model.InstructorId" style="font-weight:900;color:var(--brand);text-decoration:none;">@Model.Instructor.FullName</a>
                            @if (!string.IsNullOrEmpty(Model.Instructor.Headline))
                            {
                                <p class="course-meta mb-1">@Model.Instructor.Headline</p>
                            }
                            @if (!string.IsNullOrEmpty(Model.Instructor.Bio))
                            {
                                <p style="color:#475467;font-size:.92rem;margin-top:.7rem;line-height:1.7;">@Model.Instructor.Bio</p>
                            }
                        </div>
                    </div>
                </section>
            }
        </aside>
    </div>
</div>
