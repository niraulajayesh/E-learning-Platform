@model IReadOnlyList<UserLayer.Models.InstructorCardViewModel>
@{
    var instructors = Model ?? Array.Empty<UserLayer.Models.InstructorCardViewModel>();
    var totalCourses = instructors.Sum(i => i.PublishedCourseCount);
    var totalStudents = instructors.Sum(i => i.TotalStudents);
}

<div class="hero-dark py-5">
    <div class="container text-center">
        <span class="section-badge">Learn from the Best</span>
        <h1 class="section-title text-white mt-2">Meet Our <span class="text-gradient">Instructors</span></h1>
        <p style="color:#c4b5fd;font-size:1rem;max-width:560px;margin:1rem auto 0;">Explore instructors with published courses, learner activity, and practical expertise across the catalog.</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap mt-4" style="color:#e9d5ff;font-size:0.9rem;">
            <span><i class="bi bi-people me-1"></i><strong>@instructors.Count</strong> instructors</span>
            <span><i class="bi bi-book me-1"></i><strong>@totalCourses</strong> published courses</span>
            <span><i class="bi bi-mortarboard me-1"></i><strong>@totalStudents</strong> learners</span>
        </div>
    </div>
</div>

<div class="container py-5">
    @if (instructors.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var item in instructors)
            {
                var inst = item.Instructor;
                <div class="col">
                    <a href="/Instructors/Details/@inst.Id" class="text-decoration-none">
                        <div class="instructor-card h-100">
                            @if (!string.IsNullOrEmpty(inst.ProfilePictureUrl))
                            {
                                <img src="@inst.ProfilePictureUrl" alt="@inst.FullName" class="instructor-avatar mb-3" />
                            }
                            else
                            {
                                <div style="width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#6c2bd9,#8b5cf6);display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.8rem;font-weight:700;margin:0 auto 1rem;">
                                    @inst.FirstName.Substring(0,1)
                                </div>
                            }
                            <h2 style="font-weight:800;color:#111827;font-size:1rem;margin-bottom:0.35rem;">@inst.FullName</h2>
                            @if (!string.IsNullOrEmpty(inst.Headline))
                            {
                                <p style="color:#6b7280;font-size:0.82rem;margin-bottom:0.9rem;line-height:1.5;min-height:2.5rem;">@inst.Headline</p>
                            }
                            else
                            {
                                <p style="color:#6b7280;font-size:0.82rem;margin-bottom:0.9rem;line-height:1.5;min-height:2.5rem;">Instructor at Elearning Platform</p>
                            }
                            <div class="d-grid gap-2 mb-3" style="font-size:0.78rem;color:#6b7280;">
                                <div class="d-flex justify-content-between"><span>Courses</span><strong style="color:#111827;">@item.PublishedCourseCount</strong></div>
                                <div class="d-flex justify-content-between"><span>Learners</span><strong style="color:#111827;">@item.TotalStudents</strong></div>
                                <div class="d-flex justify-content-between"><span>Rating</span><strong style="color:#111827;">@item.AverageRating.ToString("0.0")</strong></div>
                            </div>
                            <span style="font-size:0.78rem;color:#8b5cf6;font-weight:700;"><i class="bi bi-arrow-right-circle me-1"></i>View profile</span>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="dashboard-card text-center py-5">
            <i class="bi bi-people" style="font-size:4rem;color:#d8b4fe;"></i>
            <h2 style="font-size:1.35rem;font-weight:800;margin-top:1.2rem;">No active instructors found</h2>
            <p class="text-muted mb-4">Published instructor profiles will appear here as courses are added to the catalog.</p>
            <a href="/Courses" class="btn-primary-custom">Browse Courses</a>
        </div>
    }
</div>
