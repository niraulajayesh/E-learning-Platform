@model IEnumerable<DataLayer.Entities.Category>
@{
    string[] catIcons  = { "💻", "📊", "🎨", "📸", "🎵", "📱", "🔧", "💡", "🌐", "📚" };
    string[] catColors = { "#ede9fe", "#fef3c7", "#fee2e2", "#dbeafe", "#dcfce7", "#fce7f3", "#fef9c3", "#e0f2fe" };
    var categories = Model.ToList();
}

<!-- Header -->
<div class="hero-dark py-5">
    <div class="container text-center">
        <span class="section-badge">Browse All Topics</span>
        <h1 class="section-title text-white mt-2">Explore <span class="text-gradient">Categories</span></h1>
        <p style="color:#c4b5fd;font-size:1rem;max-width:480px;margin:1rem auto 0;">Find your perfect learning path across dozens of subjects.</p>
    </div>
</div>

<div class="container py-5">
    @if (categories.Any())
    {
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4">
            @for (int i = 0; i < categories.Count; i++)
            {
                var cat = categories[i];
                <div class="col">
                    <a href="/Categories/Details/@cat.Id" class="category-card text-decoration-none">
                        <div class="category-icon" style="background:@catColors[i % catColors.Length];font-size:2rem;">
                            @catIcons[i % catIcons.Length]
                        </div>
                        <div style="font-weight:700;font-size:1rem;color:#1f2937;margin-bottom:0.25rem;">@cat.Name</div>
                        @if (!string.IsNullOrEmpty(cat.Description))
                        {
                            <div style="font-size:0.8rem;color:#6b7280;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">@cat.Description</div>
                        }
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-tags" style="font-size:4rem;color:#d8b4fe;"></i>
            <h4 class="mt-3">No categories yet</h4>
        </div>
    }
</div>
