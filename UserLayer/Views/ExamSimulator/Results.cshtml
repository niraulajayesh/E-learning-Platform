@model DataLayer.Entities.FullExamAttempt
@using System.Text.Json
@using UserLayer.Controllers
@{
    var breakdown = string.IsNullOrWhiteSpace(Model.CategoryBreakdownJson) ? new List<ExamSimulatorController.ExamCategoryScore>() : JsonSerializer.Deserialize<List<ExamSimulatorController.ExamCategoryScore>>(Model.CategoryBreakdownJson) ?? new();
}
<section class="premium-hero py-4"><div class="container"><span class="section-badge"><i class="bi bi-clipboard-check"></i> Exam Report</span><h1 class="section-title text-white mt-3 mb-2">Full ASVAB Mock Exam Results</h1><p style="color:#cbd5e1">Final score: @Model.ScorePercent% · @Model.CorrectAnswers / @Model.TotalQuestions correct</p></div></section>
<div class="container py-5"><div class="dashboard-card mb-4"><h2>Final Score</h2><div class="progress-custom my-3"><div class="progress-bar" style="width:@Model.ScorePercent%"></div></div><div class="d-flex justify-content-between"><strong>@Model.ScorePercent%</strong><span class="text-muted">Completed @Model.CompletedAt.ToLocalTime().ToString("MMM dd, yyyy h:mm tt")</span></div></div><div class="dashboard-card mb-4"><h2>Category Score Breakdown</h2><div class="row g-3">@foreach(var item in breakdown){<div class="col-md-6 col-xl-4"><div class="border rounded p-3 h-100"><div class="fw-bold">@item.Category</div><div class="display-6 fw-bold text-primary">@item.ScorePercent%</div><div class="text-muted small">@item.CorrectAnswers / @item.TotalQuestions correct</div></div></div>}</div></div><div class="dashboard-card"><h2>Exam Summary Report</h2><p class="mb-0">@Model.SummaryReport</p></div><a href="/ExamSimulator" class="btn-primary-custom mt-4" style="width:auto;">Retake Mock Exam</a></div>
