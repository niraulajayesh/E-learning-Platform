@model DataLayer.Entities.Lesson
@{
    ViewData["Title"] = "Lesson Details";
}
<div class="d-flex justify-content-between align-items-center mb-4"><div><h2>@Model.Title</h2><p class="text-muted mb-0">@Model.Section.Course.Title</p></div><div><a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a> <a asp-action="Index" asp-route-courseId="@Model.Section.CourseId" class="btn btn-outline-secondary">Back</a></div></div>
<div class="card shadow-sm border-0"><div class="card-body"><dl class="row mb-0"><dt class="col-sm-3">Type</dt><dd class="col-sm-9">@Model.Type</dd><dt class="col-sm-3">Status</dt><dd class="col-sm-9"><span class="badge @(Model.IsPublished ? "bg-success" : "bg-secondary")">@(Model.IsPublished ? "Published" : "Draft")</span></dd><dt class="col-sm-3">Video</dt><dd class="col-sm-9">@(Model.ContentUrl ?? "-")</dd><dt class="col-sm-3">PDF</dt><dd class="col-sm-9">@(Model.ResourcesUrl ?? "-")</dd><dt class="col-sm-3">Description</dt><dd class="col-sm-9">@(Model.Description ?? "-")</dd></dl></div></div>


