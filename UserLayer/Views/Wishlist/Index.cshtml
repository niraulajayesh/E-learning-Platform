@model IEnumerable<DataLayer.Entities.Wishlist>
@{
    var items = Model.ToList();
}

<div class="hero-dark" style="padding:3rem 0;">
    <div class="container">
        <span class="section-badge">Saved courses</span>
        <h1 class="section-title text-white mb-1">My Wishlist</h1>
        <p style="color:#9ca3af;margin:0;">@items.Count saved course@(items.Count == 1 ? "" : "s")</p>
    </div>
</div>

<div class="container py-5">
    @if (items.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var item in items)
            {
                var course = item.Course;
                var displayPrice = course?.DiscountedPrice ?? course?.Price ?? 0;
                <div class="col"><div class="course-card position-relative"><form method="post" action="/Wishlist/Remove" style="position:absolute;top:10px;right:10px;z-index:2;">@Html.AntiForgeryToken()<input type="hidden" name="courseId" value="@item.CourseId" /><button type="submit" style="width:34px;height:34px;border-radius:50%;background:rgba(239,68,68,0.9);border:none;color:#fff;font-size:0.9rem;display:flex;align-items:center;justify-content:center;" title="Remove from wishlist"><i class="bi bi-heart-fill"></i></button></form><div style="overflow:hidden;">@if (!string.IsNullOrEmpty(course?.ThumbnailUrl)) { <img src="@course.ThumbnailUrl" alt="@course?.Title" /> } else { <div style="height:185px;background:linear-gradient(135deg,#4c1d95,#6c2bd9);display:flex;align-items:center;justify-content:center;color:#fff;font-size:2.4rem;"><i class="bi bi-book"></i></div> }</div><div class="card-body"><h2 style="font-weight:800;color:#111827;font-size:1rem;margin-bottom:0.4rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">@(course?.Title ?? "Course")</h2>@if (course?.Instructor != null) { <p style="color:#6b7280;font-size:0.8rem;margin-bottom:0.8rem;">@course.Instructor.FullName</p> }<div class="d-flex align-items-center justify-content-between">@if (displayPrice == 0) { <span class="course-price course-price-free">Free</span> } else { <span class="course-price">$@displayPrice.ToString("0.00")</span> }<a href="/Courses/Details/@item.CourseId" class="btn-primary-custom" style="padding:0.4rem 1rem;font-size:0.82rem;">View</a></div></div></div></div>
            }
        </div>
    }
    else
    {
        <div class="dashboard-card text-center py-5"><i class="bi bi-heart" style="font-size:4rem;color:#fca5a5;"></i><h2 style="font-size:1.35rem;font-weight:800;margin-top:1.2rem;">Your wishlist is empty</h2><p class="text-muted mb-4">Save courses you are interested in and return when you are ready.</p><a href="/Courses" class="btn-primary-custom">Browse Courses</a></div>
    }
</div>