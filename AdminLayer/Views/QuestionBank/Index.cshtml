@model AdminLayer.Models.QuestionBankIndexViewModel
@{
    var topics = ViewBag.Topics as List<string> ?? new();
}
<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Question Bank</h1>
        <p class="text-muted mb-0">Manage reusable ASVAB questions for quizzes, practice tests, and mock exams.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-primary" asp-action="Builder"><i class="bi bi-magic"></i> Test Builder</a>
        <a class="btn btn-outline-primary" asp-action="MockExamBuilder"><i class="bi bi-ui-checks-grid"></i> Mock Exam</a>
        <a class="btn btn-outline-secondary" asp-action="Import"><i class="bi bi-upload"></i> Import</a>
        <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg"></i> Create Question</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Total</div><div class="h4 mb-0">@Model.TotalCount</div></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Published</div><div class="h4 mb-0 text-success">@Model.PublishedCount</div></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Draft</div><div class="h4 mb-0 text-warning">@Model.DraftCount</div></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Archived</div><div class="h4 mb-0 text-secondary">@Model.ArchivedCount</div></div></div></div>
</div>

<form class="card border-0 shadow-sm mb-4" method="get">
    <div class="card-body row g-3 align-items-end">
        <div class="col-lg-3"><label class="form-label">Search</label><input class="form-control" name="search" value="@Model.Search" /></div>
        <div class="col-lg-2"><label class="form-label">Category</label><select class="form-select" name="categoryId"><option value="">All</option>@foreach (var c in Model.Categories) { <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option> }</select></div>
        <div class="col-lg-2"><label class="form-label">Topic</label><select class="form-select" name="topic"><option value="">All</option>@foreach (var t in topics) { <option value="@t" selected="@(Model.Topic == t)">@t</option> }</select></div>
        <div class="col-lg-1"><label class="form-label">Difficulty</label><select class="form-select" name="difficulty"><option value="">All</option>@foreach (var d in new[] { "Easy", "Medium", "Hard" }) { <option value="@d" selected="@(Model.Difficulty == d)">@d</option> }</select></div>
        <div class="col-lg-1"><label class="form-label">Status</label><select class="form-select" name="status"><option value="">All</option>@foreach (var s in new[] { "Draft", "Published", "Archived" }) { <option value="@s" selected="@(Model.Status == s)">@s</option> }</select></div>
        <div class="col-lg-2"><label class="form-label">Sort</label><select class="form-select" name="sort"><option value="newest" selected="@(Model.Sort == "newest")">Newest</option><option value="oldest" selected="@(Model.Sort == "oldest")">Oldest</option><option value="most-used" selected="@(Model.Sort == "most-used")">Most Used</option><option value="least-used" selected="@(Model.Sort == "least-used")">Least Used</option></select></div>
        <div class="col-lg-1 d-grid"><button type="submit" class="btn btn-outline-primary"><i class="bi bi-search"></i></button></div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center"><strong>Questions</strong><div class="btn-group btn-group-sm"><a class="btn btn-outline-secondary" asp-action="Export" asp-route-format="csv">CSV</a><a class="btn btn-outline-secondary" asp-action="Export" asp-route-format="xlsx">Excel</a></div></div>
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light"><tr><th>Question</th><th>Category</th><th>Topic</th><th>Difficulty</th><th>Status</th><th>Used</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
            @if (!Model.Questions.Any())
            {
                <tr><td colspan="7" class="text-center text-muted py-5">No questions match the current filters.</td></tr>
            }
            @foreach (var q in Model.Questions)
            {
                <tr>
                    <td style="min-width:320px"><div class="fw-semibold">@(q.Text.Length > 120 ? q.Text[..120] + "..." : q.Text)</div><div class="small text-muted">@q.Tags</div></td>
                    <td>@q.Category?.Name</td>
                    <td>@q.Topic<br /><span class="small text-muted">@q.Subtopic</span></td>
                    <td><span class="badge bg-info-subtle text-info border border-info-subtle">@q.Difficulty</span></td>
                    <td><span class="badge @(q.Status == "Published" ? "bg-success" : q.Status == "Archived" ? "bg-secondary" : "bg-warning text-dark")">@q.Status</span></td>
                    <td>@q.PracticeTestQuestions.Count</td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            <a class="btn btn-outline-secondary" asp-action="Preview" asp-route-id="@q.Id"><i class="bi bi-eye"></i></a>
                            <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@q.Id"><i class="bi bi-pencil"></i></a>
                            <form asp-action="Duplicate" asp-route-id="@q.Id" method="post">@Html.AntiForgeryToken()<button type="submit" class="btn btn-outline-secondary"><i class="bi bi-files"></i></button></form>
                            @if (q.Status != "Published") { <form asp-action="Publish" asp-route-id="@q.Id" method="post">@Html.AntiForgeryToken()<button type="submit" class="btn btn-outline-success"><i class="bi bi-cloud-check"></i></button></form> }
                            @if (q.Status == "Published") { <form asp-action="Unpublish" asp-route-id="@q.Id" method="post">@Html.AntiForgeryToken()<button type="submit" class="btn btn-outline-warning"><i class="bi bi-cloud-slash"></i></button></form> }
                            @if (q.Status == "Archived") { <form asp-action="Restore" asp-route-id="@q.Id" method="post">@Html.AntiForgeryToken()<button type="submit" class="btn btn-outline-info"><i class="bi bi-arrow-counterclockwise"></i></button></form> }
                            @if (q.Status != "Archived") { <form asp-action="Archive" asp-route-id="@q.Id" method="post">@Html.AntiForgeryToken()<button type="submit" class="btn btn-outline-secondary"><i class="bi bi-archive"></i></button></form> }
                            <form asp-action="Delete" asp-route-id="@q.Id" method="post" data-confirm="Delete this question if it is unused?">@Html.AntiForgeryToken()<button type="submit" class="btn btn-outline-danger"><i class="bi bi-trash"></i></button></form><form asp-action="Delete" asp-route-id="@q.Id" method="post" data-confirm="Remove question bank references from quizzes/tests, then delete this question?">@Html.AntiForgeryToken()<input type="hidden" name="removeReferences" value="true" /><button type="submit" class="btn btn-outline-danger" title="Remove references and delete"><i class="bi bi-trash-fill"></i></button></form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>


