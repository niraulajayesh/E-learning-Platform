@model IEnumerable<DataLayer.Entities.PracticeTest>
@{ ViewData["Title"]="Practice Tests"; var categories=ViewBag.Categories as List<DataLayer.Entities.Category> ?? new(); int? categoryId=ViewBag.CategoryId as int?; }
<div class="d-flex justify-content-between align-items-center mb-4"><div><h2>Practice Tests</h2><p class="text-muted mb-0">Manage timed practice tests and generated mock exams.</p></div><a href="/PracticeTests/Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Add Test</a></div>
<form method="get" class="row g-2 mb-3"><div class="col-md-3"><select name="categoryId" class="form-select"><option value="">All categories</option>@foreach(var c in categories){<option value="@c.Id" selected="@(categoryId==c.Id)">@c.Name</option>}</select></div><div class="col-auto"><button type="submit" class="btn btn-outline-primary">Filter</button></div><div class="col-auto"><a href="/PracticeTests" class="btn btn-outline-secondary">Reset</a></div></form>
<div class="card shadow-sm border-0"><div class="card-body p-0"><div class="table-responsive"><table class="table table-hover mb-0 align-middle"><thead class="table-light"><tr><th>Test</th><th>Category</th><th>Type</th><th>Mode</th><th>Questions</th><th>Status</th><th class="text-end">Actions</th></tr></thead><tbody>
@if(!Model.Any()){<tr><td colspan="7" class="text-center text-muted py-5">No practice tests found.</td></tr>}
@foreach(var t in Model){<tr><td><div class="fw-semibold">@t.Title</div><div class="small text-muted">@t.Description</div></td><td>@t.Category?.Name</td><td><span class="badge @(t.IsMockExam ? "bg-dark" : "bg-info")">@(t.IsMockExam ? "Mock Exam" : "Practice Test")</span></td><td>@(t.IsTimed ? $"Timed ({t.TimeLimitMinutes} min)" : "Untimed") · Pass @t.PassingScorePercent%</td><td>@t.Questions.Count</td><td><span class="badge @(t.IsPublished ? "bg-success" : "bg-secondary")">@(t.IsPublished ? "Published" : "Draft")</span></td><td class="text-end"><div class="btn-group btn-group-sm"><a href="/PracticeTests/Preview/@t.Id" class="btn btn-outline-secondary"><i class="bi bi-eye"></i></a><a href="/PracticeTests/Edit/@t.Id" class="btn btn-outline-primary"><i class="bi bi-pencil"></i></a><form method="post" action="/PracticeTests/Duplicate/@t.Id">@Html.AntiForgeryToken()<button type="submit" class="btn btn-outline-secondary"><i class="bi bi-files"></i></button></form>@if(t.IsPublished){<form method="post" action="/PracticeTests/Unpublish/@t.Id">@Html.AntiForgeryToken()<button type="submit" class="btn btn-outline-warning"><i class="bi bi-cloud-slash"></i></button></form>}else{<form method="post" action="/PracticeTests/Publish/@t.Id">@Html.AntiForgeryToken()<button type="submit" class="btn btn-outline-success"><i class="bi bi-cloud-check"></i></button></form>}<form method="post" action="/PracticeTests/Delete/@t.Id" data-confirm="Delete this practice test?">@Html.AntiForgeryToken()<button type="submit" class="btn btn-outline-danger"><i class="bi bi-trash"></i></button></form></div></td></tr>}
</tbody></table></div></div></div>

