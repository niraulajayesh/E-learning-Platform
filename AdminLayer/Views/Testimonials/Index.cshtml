@model IEnumerable<DataLayer.Entities.Testimonial>
@{
    ViewData["Title"] = "Testimonials";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Testimonials</h2>
    <a asp-controller="Testimonials" asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Add Testimonial</a>
</div>

<div class="card shadow-sm border-0"><div class="card-body p-0"><table class="table table-hover mb-0">
<thead class="table-light"><tr><th>Student Name</th><th>Role</th><th>Rating</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
<tbody>
@if (!Model.Any()) { <tr><td colspan="5" class="text-center py-4">No testimonials found.</td></tr> }
@foreach (var testimonial in Model)
{
<tr>
    <td class="fw-semibold">@testimonial.StudentName</td>
    <td>@testimonial.StudentRole</td>
    <td>@testimonial.Rating / 5</td>
    <td><span class="badge @(testimonial.IsVisible ? "bg-success" : "bg-secondary")">@(testimonial.IsVisible ? "Published" : "Hidden")</span></td>
    <td class="text-end"><div class="dropdown"><button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">Actions</button><ul class="dropdown-menu dropdown-menu-end">
        <li><a class="dropdown-item" asp-action="Preview" asp-route-id="@testimonial.Id"><i class="bi bi-eye me-2"></i>View</a></li>
        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@testimonial.Id"><i class="bi bi-pencil me-2"></i>Edit</a></li>
        <li><form asp-action="ToggleVisibility" asp-route-id="@testimonial.Id" method="post">@Html.AntiForgeryToken()<button class="dropdown-item"><i class="bi bi-cloud-check me-2"></i>@(testimonial.IsVisible ? "Unpublish" : "Publish")</button></form></li>
        <li><hr class="dropdown-divider" /></li>
        <li><form asp-action="Delete" asp-route-id="@testimonial.Id" method="post" data-confirm="Delete testimonial? This action cannot be undone.">@Html.AntiForgeryToken()<button class="dropdown-item text-danger"><i class="bi bi-trash me-2"></i>Delete</button></form></li>
    </ul></div></td>
</tr>
}
</tbody></table></div></div>
