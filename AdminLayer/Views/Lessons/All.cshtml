@model IEnumerable<DataLayer.Entities.Course>
@{
    ViewData["Title"] = "Lessons";
    var search = ViewBag.Search as string;
    var page = (int)(ViewBag.Page ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
}
<div class="d-flex justify-content-between align-items-center mb-4"><div><h2>Lessons</h2><p class="text-muted mb-0">Choose a course to manage its lessons.</p></div><a asp-controller="Courses" asp-action="Index" class="btn btn-outline-secondary">Courses</a></div>
<form method="get" class="row g-2 mb-3"><div class="col-md-5"><input name="search" value="@search" class="form-control" placeholder="Search courses" /></div><div class="col-auto"><button class="btn btn-outline-primary"><i class="bi bi-search"></i></button></div></form>
<div class="card shadow-sm border-0"><div class="card-body p-0"><table class="table table-hover mb-0"><thead class="table-light"><tr><th>Course</th><th>Category</th><th>Lessons</th><th>Status</th><th class="text-end">Actions</th></tr></thead><tbody>
@if (!Model.Any()) { <tr><td colspan="5" class="text-center py-4">No courses found.</td></tr> }
@foreach (var course in Model)
{
<tr><td class="fw-semibold">@course.Title</td><td>@course.Category?.Name</td><td>@course.TotalLessons</td><td><span class="badge bg-secondary">@course.Status</span></td><td class="text-end"><a asp-action="Index" asp-route-courseId="@course.Id" class="btn btn-sm btn-outline-info">Manage Lessons</a> <a asp-action="Create" asp-route-courseId="@course.Id" class="btn btn-sm btn-primary">Add Lesson</a></td></tr>
}
</tbody></table></div></div>
@if (totalPages > 1){<nav class="mt-3"><ul class="pagination">@for(var i=1;i<=totalPages;i++){<li class="page-item @(i==page?"active":"")"><a class="page-link" href="/Lessons?search=@search&page=@i">@i</a></li>}</ul></nav>}
