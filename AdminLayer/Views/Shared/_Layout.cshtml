<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f6f7f9; }
        .sidebar {
            min-height: 100vh;
            background-color: #212529;
        }
        .sidebar a {
            color: #adb5bd;
            text-decoration: none;
            padding: 10px 20px;
            display: block;
        }
        .sidebar a:hover, .sidebar a.active { color: #fff; background-color: #343a40; }
        .content-wrapper { padding: 20px; }
        .navbar-top {
            background-color: #fff;
            box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);
        }
        .table td, .table th { vertical-align: middle; }
        .admin-thumb { width: 72px; height: 44px; object-fit: cover; border-radius: 6px; background: #e9ecef; }
        .admin-mobile-toggle { display: none; }

        @@media (max-width: 991.98px) {
            .sidebar { width: 100% !important; position: fixed; z-index: 1030; inset: 0 auto 0 0; max-width: 270px; transform: translateX(-100%); transition: transform .25s ease; }
            .sidebar.show { transform: translateX(0); }
            .admin-backdrop.show { position: fixed; inset: 0; background: rgba(0,0,0,.4); z-index: 1029; }
            .admin-mobile-toggle { display: inline-flex; }
            .content-wrapper { padding: 15px; }
            .sidebar-link-collapse { display: block; }
        }
    </style>
</head>
<body>
    <a class="skip-link" href="#admin-main-content">Skip to content</a>
    <div class="d-flex">
        <div class="sidebar flex-shrink-0" id="adminSidebar" style="width: 250px;">
            <div class="p-4 text-white text-center fw-bold fs-5 border-bottom border-secondary">
                <i class="bi bi-mortarboard-fill me-2"></i> E-Learning Admin
            </div>
            <div class="mt-3">
                <a href="/Home" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
                <a href="/Users" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")"><i class="bi bi-people me-2"></i> Users</a>
                <a href="/Categories" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categories" ? "active" : "")"><i class="bi bi-tags me-2"></i> Categories</a>
                <a href="/Courses" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Courses" ? "active" : "")"><i class="bi bi-book me-2"></i> Courses</a>
                <a href="/Lessons" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Lessons" ? "active" : "")"><i class="bi bi-play-btn me-2"></i> Lessons</a>
                <a href="/Quizzes" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Quizzes" ? "active" : "")"><i class="bi bi-question-square me-2"></i> Quizzes</a>
                <a href="/QuestionBank" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "QuestionBank" ? "active" : "")"><i class="bi bi-database-check me-2"></i> Question Bank</a>
                <a href="/Flashcards" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Flashcards" ? "active" : "")"><i class="bi bi-card-text me-2"></i> Flashcards</a>
                <a href="/StudyGuides" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "StudyGuides" ? "active" : "")"><i class="bi bi-journal-text me-2"></i> Study Guides</a>
                <a href="/PracticeTests" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "PracticeTests" ? "active" : "")"><i class="bi bi-stopwatch me-2"></i> Practice Tests</a>
                <a href="/Testimonials" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Testimonials" ? "active" : "")"><i class="bi bi-chat-quote me-2"></i> Testimonials</a>
                <a href="/Banners" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Banners" ? "active" : "")"><i class="bi bi-images me-2"></i> Banners</a>
                <a href="/SiteSettings" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "SiteSettings" ? "active" : "")"><i class="bi bi-gear me-2"></i> Settings</a>
            </div>
        </div>

        <div id="adminBackdrop" class="admin-backdrop d-none"></div>

        <div class="flex-grow-1 d-flex flex-column" style="min-width: 0;">
            <nav class="navbar navbar-expand-lg navbar-light navbar-top px-4 py-3">
                <div class="container-fluid">
                    <button class="btn btn-outline-secondary admin-mobile-toggle d-lg-none me-3" type="button" id="adminMenuBtn" aria-label="Toggle admin sidebar"><i class="bi bi-list"></i></button>
                    <span class="navbar-brand mb-0 h1">@ViewData["Title"]</span>
                    <div class="d-flex align-items-center gap-3">
                        <span class="badge bg-success-subtle text-success border border-success-subtle">Admin only</span>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Auth" asp-action="Logout" class="btn btn-sm btn-outline-secondary"><i class="bi bi-box-arrow-right"></i></a>
                        }
                    </div>
                </div>
            </nav>

            <main id="admin-main-content" class="content-wrapper" tabindex="-1">
                @RenderBody()
            </main>
        </div>
    </div>

    <div class="toast-container position-fixed top-0 end-0 p-3">
        @if (TempData["Success"] != null)
        {
            <div class="toast text-bg-success border-0" role="alert" data-bs-delay="4500"><div class="d-flex"><div class="toast-body">@TempData["Success"]</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div></div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast text-bg-danger border-0" role="alert" data-bs-delay="6500"><div class="d-flex"><div class="toast-body">@TempData["Error"]</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div></div>
        }
    </div>


    <div class="modal fade" id="adminConfirmModal" tabindex="-1" aria-labelledby="adminConfirmTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="adminConfirmTitle">Confirm Action</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p id="adminConfirmMessage" class="mb-0">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="adminConfirmSubmit">Delete</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.querySelectorAll('.toast').forEach(toast => bootstrap.Toast.getOrCreateInstance(toast).show());
        const sidebar = document.getElementById('adminSidebar');
        const backdrop = document.getElementById('adminBackdrop');
        const menuBtn = document.getElementById('adminMenuBtn');
        if (menuBtn) {
            menuBtn.addEventListener('click', function () {
                sidebar.classList.toggle('show');
                backdrop.classList.toggle('d-none');
                backdrop.classList.toggle('show');
            });
        }
        if (backdrop) {
            backdrop.addEventListener('click', function() {
                sidebar.classList.remove('show');
                backdrop.classList.add('d-none');
                backdrop.classList.remove('show');
            });
        }
        const confirmModalEl = document.getElementById('adminConfirmModal');
        const confirmMessage = document.getElementById('adminConfirmMessage');
        const confirmSubmit = document.getElementById('adminConfirmSubmit');
        let pendingConfirmForm = null;
        let pendingConfirmSubmitter = null;
        if (confirmModalEl && confirmSubmit) {
            const confirmModal = bootstrap.Modal.getOrCreateInstance(confirmModalEl);
            document.querySelectorAll('form[data-confirm], button[data-confirm]').forEach(element => element.addEventListener('click', event => {
                const form = element.tagName === 'FORM' ? element : element.form;
                if (!form || form.dataset.confirmed === 'true') return;
                event.preventDefault();
                pendingConfirmForm = form;
                pendingConfirmSubmitter = element.tagName === 'BUTTON' ? element : null;
                confirmMessage.textContent = element.dataset.confirm || form.dataset.confirm || 'This action cannot be undone.';
                confirmSubmit.textContent = /delete|remove|archive/i.test(confirmMessage.textContent) ? 'Delete' : 'Confirm';
                confirmModal.show();
            }));
            confirmSubmit.addEventListener('click', () => {
                if (!pendingConfirmForm) return;
                pendingConfirmForm.dataset.confirmed = 'true';
                confirmModal.hide();
                pendingConfirmSubmitter ? pendingConfirmForm.requestSubmit(pendingConfirmSubmitter) : pendingConfirmForm.requestSubmit();
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>










