@model DataLayer.Entities.StudyGuide
@{
    var categories = ViewData["Categories"] as List<DataLayer.Entities.Category> ?? new();
}
<div class="card shadow-sm border-0"><div class="card-body"><form method="post">@Html.AntiForgeryToken()<div asp-validation-summary="All" class="text-danger admin-form-alert mb-3"></div><div class="row"><div class="col-md-5 mb-3"><label class="form-label fw-bold">Title</label><input asp-for="Title" class="form-control" required /></div><div class="col-md-4 mb-3"><label class="form-label fw-bold">Category</label><select asp-for="CategoryId" class="form-select" required><option value="">Select category</option>@foreach(var c in categories){<option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option>}</select></div><div class="col-md-1 mb-3"><label class="form-label fw-bold">Order</label><input asp-for="DisplayOrder" type="number" class="form-control" /></div><div class="col-md-2 mb-3 d-flex align-items-end"><div class="form-check"><input asp-for="IsPublished" class="form-check-input" /><label asp-for="IsPublished" class="form-check-label">Published</label></div></div></div><div class="mb-3"><label class="form-label fw-bold">Summary</label><textarea asp-for="Summary" class="form-control" rows="2"></textarea></div><div class="mb-3"><label class="form-label fw-bold">Theory</label><textarea asp-for="Theory" class="form-control" rows="5" required></textarea></div><div class="mb-3"><label class="form-label fw-bold">Examples</label><textarea asp-for="Examples" class="form-control" rows="5" required></textarea></div><div class="mb-3"><label class="form-label fw-bold">Key Concepts</label><textarea asp-for="KeyConcepts" class="form-control" rows="4" required></textarea></div><div class="mb-3"><label class="form-label fw-bold">Tips</label><textarea asp-for="Tips" class="form-control" rows="4" required></textarea></div><div class="admin-save-bar"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save Guide</button></div></form></div></div>

