@using SharedLayer.Enums
@model IEnumerable<DataLayer.Entities.Course>
@{
    ViewData["Title"] = "Courses";
    var categories = ViewBag.Categories as List<DataLayer.Entities.Category> ?? new();
    var instructors = ViewBag.Instructors as List<DataLayer.Entities.User> ?? new();
    var search = ViewBag.Search as string;
    var categoryId = ViewBag.CategoryId as int?;
    var status = ViewBag.Status as CourseStatus?;
    var instructorId = ViewBag.InstructorId as Guid?;
    var page = (int)(ViewBag.Page ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h2 class="mb-1">Courses</h2><p class="text-muted mb-0">@ViewBag.TotalItems total courses</p></div>
    <a asp-controller="Courses" asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Add Course</a>
</div>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-3"><input name="search" value="@search" class="form-control" placeholder="Search courses" /></div>
    <div class="col-md-2"><select name="categoryId" class="form-select"><option value="">All categories</option>@foreach (var c in categories){<option value="@c.Id" selected="@(categoryId == c.Id)">@c.Name</option>}</select></div>
    <div class="col-md-2"><select name="instructorId" class="form-select"><option value="">All instructors</option>@foreach (var instructor in instructors){<option value="@instructor.Id" selected="@(instructorId == instructor.Id)">@instructor.FullName</option>}</select></div>
    <div class="col-md-2"><select name="status" class="form-select"><option value="">All status</option>@foreach (var s in Enum.GetValues<CourseStatus>()){<option value="@s" selected="@(status == s)">@s</option>}</select></div>
    <div class="col-auto"><button class="btn btn-outline-primary"><i class="bi bi-search"></i></button></div>
    <div class="col-auto"><a href="/Courses" class="btn btn-outline-secondary">Reset</a></div>
</form>
<div class="card shadow-sm border-0"><div class="card-body p-0">
<table class="table table-hover mb-0">
<thead class="table-light"><tr><th>Course</th><th>Category</th><th>Price</th><th>Status</th><th>Featured</th><th>Enrollments</th><th class="text-end">Actions</th></tr></thead>
<tbody>
@if (!Model.Any()) { <tr><td colspan="7" class="text-center py-4">No courses found.</td></tr> }
@foreach (var course in Model)
{
    <tr>
        <td><div class="d-flex align-items-center gap-2">@if(!string.IsNullOrWhiteSpace(course.ThumbnailUrl)){<img src="@course.ThumbnailUrl" class="admin-thumb" alt="" />}<div><div class="fw-semibold">@course.Title</div><div class="small text-muted">@course.Slug</div></div></div></td>
        <td>@course.Category?.Name</td>
        <td>$@course.Price</td>
        <td><span class="badge @(course.Status == CourseStatus.Published ? "bg-success" : course.Status == CourseStatus.Archived ? "bg-secondary" : "bg-warning text-dark")">@course.Status</span></td>
        <td><span class="badge @(course.IsFeatured ? "bg-info text-dark" : "bg-light text-dark border")">@(course.IsFeatured ? "Featured" : "Standard")</span></td>
        <td>@course.TotalEnrollments</td>
        <td class="text-end">
            <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></a>
            <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
            <a asp-controller="Lessons" asp-action="Index" asp-route-courseId="@course.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-list-ul"></i></a>
            <form asp-action="ToggleFeatured" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@course.Id" /><button class="btn btn-sm btn-outline-dark"><i class="bi bi-star"></i></button></form>
            @if (course.Status == CourseStatus.Published)
            {<form asp-action="Unpublish" method="post" class="d-inline" data-confirm="Unpublish this course?">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@course.Id" /><button class="btn btn-sm btn-outline-warning"><i class="bi bi-eye-slash"></i></button></form>}
            else
            {<form asp-action="Publish" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@course.Id" /><button class="btn btn-sm btn-outline-success"><i class="bi bi-cloud-upload"></i></button></form>}
            <form asp-action="Delete" method="post" class="d-inline" data-confirm="Archive this course? Lessons, enrollments, reviews, quizzes, and certificates will be kept safely.">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@course.Id" /><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form>
        </td>
    </tr>
}
</tbody></table></div></div>
@if (totalPages > 1){<nav class="mt-3"><ul class="pagination">@for (var i=1;i<=totalPages;i++){<li class="page-item @(i==page?"active":"")"><a class="page-link" href="/Courses?search=@search&categoryId=@categoryId&status=@status&page=@i">@i</a></li>}</ul></nav>}
