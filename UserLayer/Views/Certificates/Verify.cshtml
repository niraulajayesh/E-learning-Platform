@model DataLayer.Entities.Certificate
@{
    var missing = (bool)(ViewBag.NotFound ?? false);
    var studentName = !missing && !string.IsNullOrWhiteSpace(Model?.Student?.FullName) ? Model.Student.FullName : "Unavailable";
    var courseName = !missing && !string.IsNullOrWhiteSpace(Model?.Course?.Title) ? Model.Course.Title : "Unavailable";
    var instructorName = !missing && !string.IsNullOrWhiteSpace(Model?.Course?.Instructor?.FullName) ? Model.Course.Instructor.FullName : "LearnHub Instructor";
}

<section class="premium-hero py-5">
    <div class="container text-center">
        <span class="section-badge"><i class="bi bi-shield-check"></i> Certificate verification</span>
        <h1 class="section-title text-white mt-3 mb-2">Verify Certificate</h1>
        <p style="color:#cbd5e1;margin:0;">Confirm that a LearnHub credential is authentic and currently valid.</p>
    </div>
</section>

<div class="container py-5">
    @if (missing)
    {
        <div class="dashboard-card text-center py-5 mx-auto" style="max-width:760px;">
            <i class="bi bi-x-circle" style="font-size:4rem;color:#ef4444;"></i>
            <h2 class="mt-3" style="font-weight:900;">Certificate not found</h2>
            <p class="text-muted mb-0">Check the certificate link or certificate number and try again.</p>
        </div>
    }
    else
    {
        <div class="dashboard-card mx-auto" style="max-width:860px;padding:0;overflow:hidden;">
            <div style="background:linear-gradient(135deg,#0b1220,#173b52);color:#fff;padding:2rem;">
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <div style="width:64px;height:64px;border-radius:18px;background:#dcfae6;color:#067647;display:grid;place-items:center;font-size:2rem;"><i class="bi bi-shield-check"></i></div>
                    <div>
                        <div style="font-size:.78rem;text-transform:uppercase;letter-spacing:.12em;color:#93c5fd;font-weight:900;">Verification status</div>
                        <h2 style="font-weight:900;margin:0;">Valid LearnHub Certificate</h2>
                    </div>
                </div>
            </div>
            <div class="p-4 p-lg-5">
                <div class="row g-4">
                    <div class="col-lg-7">
                        <div class="d-grid gap-3">
                            <div><div class="course-meta text-uppercase fw-bold">Student</div><h3 style="font-weight:900;">@studentName</h3></div>
                            <div><div class="course-meta text-uppercase fw-bold">Course</div><h4 style="font-weight:900;color:var(--brand);">@courseName</h4></div>
                            <div><div class="course-meta text-uppercase fw-bold">Instructor</div><strong>@instructorName</strong></div>
                        </div>
                    </div>
                    <div class="col-lg-5">
                        <div style="border:1px solid var(--line);border-radius:14px;padding:1rem;background:#f8fafc;">
                            <div class="mb-3"><div class="course-meta text-uppercase fw-bold">Issue Date</div><strong>@Model!.IssuedAt.ToString("MMMM dd, yyyy")</strong></div>
                            <div class="mb-3"><div class="course-meta text-uppercase fw-bold">Certificate ID</div><strong style="font-family:monospace;word-break:break-all;">@Model.CertificateNumber</strong></div>
                            <div><div class="course-meta text-uppercase fw-bold">Verification</div><span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle">Active</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
