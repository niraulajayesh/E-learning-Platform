@model DataLayer.Entities.PracticeTest
@{ ViewData["Title"] = "Practice Test Preview"; var questions = Model.Questions.OrderBy(q => q.Order).ToList(); }
<div class="d-flex justify-content-between align-items-center mb-4"><div><h2>@Model.Title</h2><p class="text-muted mb-0">@Model.Category?.Name · @(Model.IsMockExam ? "Mock Exam" : "Practice Test")</p></div><div class="d-flex gap-2"><a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a><a asp-action="Index" class="btn btn-outline-secondary">Back</a></div></div>
<div class="card border-0 shadow-sm mb-4"><div class="card-body"><div class="d-flex flex-wrap gap-2 mb-3"><span class="badge @(Model.IsPublished ? "bg-success" : "bg-secondary")">@(Model.IsPublished ? "Published" : "Draft")</span><span class="badge bg-light text-dark border">@questions.Count questions</span><span class="badge bg-light text-dark border">Pass @Model.PassingScorePercent%</span>@if(Model.IsTimed){<span class="badge bg-light text-dark border">@Model.TimeLimitMinutes min</span>}</div><p class="text-muted mb-0">@Model.Description</p></div></div>
<div class="d-grid gap-3">@foreach(var q in questions){var opts=new[]{("A",q.OptionA),("B",q.OptionB),("C",q.OptionC),("D",q.OptionD),("E",q.OptionE),("F",q.OptionF)}.Where(o=>!string.IsNullOrWhiteSpace(o.Item2));<section class="card border-0 shadow-sm"><div class="card-body"><h3 class="h6">@q.Order. @q.Text</h3><div class="d-grid gap-2">@foreach(var opt in opts){<div class="p-2 border rounded @(q.CorrectOption==opt.Item1 ? "border-success bg-success-subtle" : "")"><strong>@opt.Item1.</strong> @opt.Item2</div>}</div><p class="small text-muted mt-2 mb-0">@q.Explanation</p></div></section>}</div>
