@model DataLayer.Entities.Certificate
@{
    var studentName = !string.IsNullOrWhiteSpace(Model.Student?.FullName) ? Model.Student.FullName : "Student name unavailable";
    var courseName = !string.IsNullOrWhiteSpace(Model.Course?.Title) ? Model.Course.Title : "Course name unavailable";
    var instructorName = !string.IsNullOrWhiteSpace(Model.Course?.Instructor?.FullName) ? Model.Course.Instructor.FullName : "LearnHub Instructor";
    var verificationPath = !string.IsNullOrWhiteSpace(Model.VerificationUrl) ? Model.VerificationUrl : $"/Certificates/Verify/{Model.Id}";
    var verificationUrl = verificationPath.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? verificationPath : $"{Context.Request.Scheme}://{Context.Request.Host}{verificationPath}";
    var qrUrl = "https://api.qrserver.com/v1/create-qr-code/?size=180x180&margin=10&data=" + System.Net.WebUtility.UrlEncode(verificationUrl);
}

@section Styles {
    <style>
        .certificate-stage { background: linear-gradient(180deg,#f8fafc 0%,#eef3ff 100%); }
        .certificate-actions { position: sticky; top: 88px; z-index: 10; }
        .premium-certificate {
            position: relative;
            overflow: hidden;
            max-width: 1080px;
            min-height: 690px;
            margin: 0 auto;
            padding: 3.5rem;
            color: #172033;
            background: linear-gradient(135deg,#fffdf7 0%,#ffffff 45%,#f7fbff 100%);
            border: 1px solid #e7d39a;
            box-shadow: 0 28px 80px rgba(16,24,40,.16);
        }
        .premium-certificate:before,
        .premium-certificate:after {
            content: "";
            position: absolute;
            inset: 22px;
            border: 2px solid #d9b65d;
            pointer-events: none;
        }
        .premium-certificate:after { inset: 38px; border: 1px solid rgba(217,182,93,.38); }
        .cert-corner { position:absolute;width:118px;height:118px;border-color:#d9b65d;opacity:.78; }
        .cert-corner.tl { top:42px;left:42px;border-top:4px solid;border-left:4px solid; }
        .cert-corner.tr { top:42px;right:42px;border-top:4px solid;border-right:4px solid; }
        .cert-corner.bl { bottom:42px;left:42px;border-bottom:4px solid;border-left:4px solid; }
        .cert-corner.br { bottom:42px;right:42px;border-bottom:4px solid;border-right:4px solid; }
        .cert-body { position: relative; z-index: 2; }
        .cert-brand { display:flex;align-items:center;justify-content:center;gap:.75rem;font-family:'Outfit',sans-serif;font-weight:900;font-size:1.35rem;color:#111827; }
        .cert-logo { width:44px;height:44px;border-radius:14px;display:grid;place-items:center;background:linear-gradient(135deg,#172033,#3157d5);color:#fff;box-shadow:0 12px 28px rgba(49,87,213,.24); }
        .cert-kicker { margin-top:1rem;color:#7c6a37;font-weight:900;letter-spacing:.18em;text-transform:uppercase;font-size:.76rem; }
        .cert-title { font-family:'Outfit',sans-serif;font-weight:900;font-size:clamp(2.15rem,4vw,3.4rem);letter-spacing:0;color:#172033; }
        .cert-student { font-family:'Outfit',sans-serif;font-weight:900;font-size:clamp(2.5rem,5.5vw,4.5rem);line-height:1.02;color:#0b1220;margin:1rem 0;border-bottom:2px solid rgba(217,182,93,.55);display:inline-block;padding:0 .75rem .35rem; }
        .cert-course { color:#3157d5;font-family:'Outfit',sans-serif;font-weight:900;font-size:clamp(1.45rem,3vw,2.25rem);max-width:820px;margin:0 auto; }
        .cert-meta-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:2.5rem; }
        .cert-meta { border:1px solid #ece3c7;background:rgba(255,255,255,.72);padding:1rem;border-radius:12px; }
        .cert-meta span { display:block;color:#667085;font-size:.76rem;font-weight:900;text-transform:uppercase;letter-spacing:.08em;margin-bottom:.35rem; }
        .cert-meta strong { display:block;color:#172033;font-weight:900;word-break:break-word; }
        .cert-footer { display:grid;grid-template-columns:1fr auto 1fr;align-items:end;gap:1.5rem;margin-top:2.8rem; }
        .signature-line { border-top:2px solid #172033;padding-top:.55rem;text-align:center;font-weight:900; }
        .signature-line small { display:block;color:#667085;font-weight:700;margin-top:.2rem; }
        .cert-seal { width:118px;height:118px;border-radius:50%;display:grid;place-items:center;text-align:center;border:3px solid #d9b65d;color:#7c5d14;background:radial-gradient(circle,#fff8dd,#f0d37c);font-family:'Outfit',sans-serif;font-weight:900;box-shadow:0 16px 34px rgba(124,93,20,.18); }
        .cert-qr { width:118px;border:1px solid #ece3c7;border-radius:12px;padding:.55rem;background:#fff;margin:1.2rem auto 0; }
        .cert-qr img { width:100%;display:block; }
        @@media (max-width: 767.98px) {
            .certificate-actions { position: static; }
            .premium-certificate { padding:2.25rem 1.25rem;min-height:auto; }
            .premium-certificate:before { inset:14px; }
            .premium-certificate:after, .cert-corner { display:none; }
            .cert-meta-grid, .cert-footer { grid-template-columns:1fr; }
            .cert-seal { margin:0 auto; }
        }
        @@media print {
            .navbar-main, .footer-main, .certificate-actions, .hero-dark { display:none!important; }
            body { background:#fff!important; }
            .certificate-stage { padding:0!important;background:#fff!important; }
            .premium-certificate { box-shadow:none;max-width:none;min-height:690px; }
        }
    </style>
}

<section class="premium-hero py-4">
    <div class="container d-flex align-items-center justify-content-between gap-3 flex-wrap">
        <div>
            <span class="section-badge"><i class="bi bi-award"></i> Certificate earned</span>
            <h1 class="section-title text-white mt-2 mb-0">Certificate of Completion</h1>
        </div>
        <div class="course-count-chip" style="background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.22);color:#fff;"><i class="bi bi-shield-check"></i> Verified credential</div>
    </div>
</section>

<section class="certificate-stage py-5">
    <div class="container">
        <div class="certificate-actions d-flex justify-content-center gap-2 flex-wrap mb-4">
            <a href="/Certificates/Download/@Model.Id" class="btn-primary-custom" id="downloadCertificate"><i class="bi bi-download"></i> Download PDF</a>
            <a href="@verificationPath" target="_blank" class="btn-outline-custom"><i class="bi bi-shield-check"></i> Verify</a>
            <button type="button" class="btn-outline-custom" onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
        </div>

        <article class="premium-certificate text-center" aria-label="Certificate of Completion">
            <span class="cert-corner tl"></span><span class="cert-corner tr"></span><span class="cert-corner bl"></span><span class="cert-corner br"></span>
            <div class="cert-body">
                <div class="cert-brand"><span class="cert-logo"><i class="bi bi-mortarboard-fill"></i></span><span>LearnHub</span></div>
                <div class="cert-kicker">Professional Learning Credential</div>
                <h2 class="cert-title mt-3">Certificate of Completion</h2>
                <p class="mt-4 mb-1 text-muted fw-bold">This certifies that</p>
                <div class="cert-student">@studentName</div>
                <p class="text-muted fw-bold mb-2">has successfully completed</p>
                <div class="cert-course">@courseName</div>

                <div class="cert-meta-grid text-start">
                    <div class="cert-meta"><span>Instructor</span><strong>@instructorName</strong></div>
                    <div class="cert-meta"><span>Completion Date</span><strong>@Model.IssuedAt.ToString("MMMM dd, yyyy")</strong></div>
                    <div class="cert-meta"><span>Certificate ID</span><strong style="font-family:monospace;font-size:.85rem;">@Model.CertificateNumber</strong></div>
                </div>

                <div class="cert-qr">
                    <img src="@qrUrl" alt="QR code to verify certificate" />
                </div>
                <div class="mt-2 course-meta" style="font-size:.76rem;word-break:break-all;">@verificationUrl</div>

                <div class="cert-footer">
                    <div class="signature-line">@instructorName<small>Instructor Signature</small></div>
                    <div class="cert-seal">OFFICIAL<br />LEARNHUB<br />SEAL</div>
                    <div class="signature-line">LearnHub Registrar<small>Platform Signature</small></div>
                </div>
            </div>
        </article>
    </div>
</section>

@section Scripts {
    <script>
        const downloadButton = document.getElementById('downloadCertificate');
        if (downloadButton) {
            downloadButton.addEventListener('click', function () {
                const original = this.innerHTML;
                this.innerHTML = '<span class="spinner-border spinner-border-sm" aria-hidden="true"></span> Preparing PDF';
                setTimeout(() => this.innerHTML = original, 2500);
            });
        }
    </script>
}
