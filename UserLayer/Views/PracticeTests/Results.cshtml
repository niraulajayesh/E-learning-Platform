@model DataLayer.Entities.PracticeTestAttempt
@using System.Text.Json
@{
    var answers = string.IsNullOrWhiteSpace(Model.AnswersJson) ? new Dictionary<string,string>() : JsonSerializer.Deserialize<Dictionary<string,string>>(Model.AnswersJson) ?? new();
    var questions = Model.PracticeTest.Questions.OrderBy(q => q.Order).ToList();
}
<section class="premium-hero py-4"><div class="container"><span class="section-badge"><i class="bi bi-clipboard-check"></i> Results</span><h1 class="section-title text-white mt-3 mb-2">@Model.PracticeTest.Title</h1><p style="color:#cbd5e1">Score: @Model.ScorePercent% · @Model.CorrectAnswers / @Model.TotalQuestions correct</p></div></section>
<div class="container py-5"><div class="dashboard-card mb-4"><div class="progress-custom"><div class="progress-bar" style="width:@Model.ScorePercent%"></div></div><div class="d-flex justify-content-between mt-2"><strong>@Model.ScorePercent%</strong><span class="text-muted">Completed @Model.CompletedAt.ToLocalTime().ToString("MMM dd, yyyy h:mm tt")</span></div></div><div class="d-grid gap-4">@foreach(var q in questions){ var selected = answers.TryGetValue(q.Id.ToString(), out var s) ? s : ""; var correct = string.Equals(selected, q.CorrectOption, StringComparison.OrdinalIgnoreCase); <div class="dashboard-card"><div class="d-flex justify-content-between"><h2 style="font-size:1.1rem">@q.Order. @q.Text</h2><span class="badge @(correct ? "bg-success" : "bg-danger")">@(correct ? "Correct" : "Review")</span></div><p class="mb-1"><strong>Your answer:</strong> @(string.IsNullOrWhiteSpace(selected) ? "No answer" : selected)</p><p class="mb-1"><strong>Correct answer:</strong> @q.CorrectOption</p><p class="mb-0 text-muted">@q.Explanation</p></div>}</div><a href="/PracticeTests" class="btn-primary-custom mt-4" style="width:auto;">Back to Tests</a></div>
