@model IEnumerable<DataLayer.Entities.Category>
@{
    ViewData["Title"] = "Categories";
    var search = ViewBag.Search as string;
    var page = (int)(ViewBag.Page ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Categories</h2>
        <p class="text-muted mb-0">@ViewBag.TotalItems total categories</p>
    </div>
    <a href="/Categories/Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Add Category</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-5"><input name="search" value="@search" class="form-control" placeholder="Search categories" /></div>
    <div class="col-auto"><button class="btn btn-outline-primary" type="submit"><i class="bi bi-search"></i></button></div>
    <div class="col-auto"><a href="/Categories" class="btn btn-outline-secondary">Reset</a></div>
</form>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Slug</th><th>Status</th><th>Courses</th><th class="text-end">Actions</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any()) { <tr><td colspan="5" class="text-center py-4">No categories found.</td></tr> }
                @foreach (var category in Model)
                {
                    var activeCourses = category.Courses.Count(c => c.Status != SharedLayer.Enums.CourseStatus.Archived);
                    <tr>
                        <td class="fw-semibold">@category.Name</td>
                        <td>@category.Slug</td>
                        <td><span class="badge @(category.IsActive ? "bg-success" : "bg-secondary")">@(category.IsActive ? "Active" : "Inactive")</span></td>
                        <td>@activeCourses active</td>
                        <td class="text-end">
                            <a href="/Categories/Details/@category.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></a>
                            <a href="/Categories/Edit/@category.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <form action="/Categories/Delete" method="post" class="d-inline" data-confirm="@(activeCourses > 0 ? "This category has active courses. Confirming will deactivate the category instead of removing course history." : "Delete this category?")">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@category.Id" />
                                <input type="hidden" name="confirmWithCourses" value="@(activeCourses > 0 ? "true" : "false")" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3"><ul class="pagination">
        @for (var i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == page ? "active" : "")"><a class="page-link" href="/Categories?search=@search&page=@i">@i</a></li>
        }
    </ul></nav>
}

