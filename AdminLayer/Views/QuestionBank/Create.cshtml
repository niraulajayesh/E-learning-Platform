@model DataLayer.Entities.QuestionBankQuestion
<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 mb-1">Create Question</h1><p class="text-muted mb-0">Add a reusable ASVAB question to the central bank.</p></div>
    <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left"></i> Back</a>
</div>
<div class="card border-0 shadow-sm"><div class="card-body">
<form asp-action="Create" method="post">@Html.AntiForgeryToken()<partial name="_QuestionForm" model="Model" /><div class="admin-save-bar"><button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> Save Question</button><a class="btn btn-outline-secondary" asp-action="Index">Cancel</a></div></form>
</div></div>

