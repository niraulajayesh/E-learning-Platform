@model AdminLayer.Models.QuizIndexViewModel
@{ ViewData["Title"] = "Quizzes"; }
<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div><h2>Quizzes</h2><p class="text-muted mb-0">Manage lesson quizzes and their questions from one screen.</p></div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Create Quiz</a>
</div>
<form method="get" class="card border-0 shadow-sm mb-4"><div class="card-body row g-3 align-items-end">
    <div class="col-md-5"><label class="form-label">Search</label><input class="form-control" name="search" value="@Model.Search" /></div>
    <div class="col-md-3"><label class="form-label">Status</label><select class="form-select" name="isPublished"><option value="">All</option><option value="true" selected="@(Model.IsPublished == true)">Published</option><option value="false" selected="@(Model.IsPublished == false)">Draft</option></select></div>
    <div class="col-md-2"><button class="btn btn-outline-primary w-100"><i class="bi bi-search"></i> Filter</button></div>
    <div class="col-md-2"><a asp-action="All" class="btn btn-outline-secondary w-100">Reset</a></div>
</div></form>
<div class="card shadow-sm border-0"><div class="card-body p-0"><div class="table-responsive"><table class="table table-hover mb-0 align-middle"><thead class="table-light"><tr><th>Quiz</th><th>Lesson</th><th>Course</th><th>Questions</th><th>Pass</th><th>Status</th><th class="text-end">Actions</th></tr></thead><tbody>
@if (!Model.Quizzes.Any()) { <tr><td colspan="7" class="text-center text-muted py-5">No quizzes found.</td></tr> }
@foreach (var quiz in Model.Quizzes)
{
    <tr>
        <td><div class="fw-semibold">@quiz.Title</div><div class="small text-muted">@quiz.Description</div></td>
        <td>@quiz.Lesson?.Title</td>
        <td>@quiz.Lesson?.Section?.Course?.Title</td>
        <td>@quiz.Questions.Count</td>
        <td>@quiz.PassingScore%</td>
        <td><span class="badge @(quiz.IsPublished ? "bg-success" : "bg-secondary")">@(quiz.IsPublished ? "Published" : "Draft")</span></td>
        <td class="text-end"><div class="btn-group btn-group-sm">
            <a asp-action="Details" asp-route-id="@quiz.Id" class="btn btn-outline-secondary"><i class="bi bi-eye"></i></a>
            <a asp-action="Edit" asp-route-id="@quiz.Id" class="btn btn-outline-primary"><i class="bi bi-pencil"></i></a>
            @if (quiz.IsPublished) { <form asp-action="Unpublish" asp-route-id="@quiz.Id" method="post">@Html.AntiForgeryToken()<button class="btn btn-outline-warning"><i class="bi bi-cloud-slash"></i></button></form> }
            else { <form asp-action="Publish" asp-route-id="@quiz.Id" method="post">@Html.AntiForgeryToken()<button class="btn btn-outline-success"><i class="bi bi-cloud-check"></i></button></form> }
            <form asp-action="Delete" asp-route-id="@quiz.Id" method="post" data-confirm="Delete this quiz and all attempts?">@Html.AntiForgeryToken()<button class="btn btn-outline-danger"><i class="bi bi-trash"></i></button></form>
        </div></td>
    </tr>
}
</tbody></table></div></div></div>
