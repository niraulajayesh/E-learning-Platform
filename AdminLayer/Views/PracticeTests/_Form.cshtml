@model DataLayer.Entities.PracticeTest
@{ var categories=ViewData["Categories"] as List<DataLayer.Entities.Category> ?? new(); var questions=Model.Questions?.OrderBy(q=>q.Order).ToList() ?? new(); var bankQuestions=ViewBag.BankQuestions as List<DataLayer.Entities.QuestionBankQuestion> ?? new(); }
<div class="card shadow-sm border-0"><div class="card-body"><form method="post">@Html.AntiForgeryToken()<div asp-validation-summary="All" class="text-danger admin-form-alert mb-3"></div><div class="row g-3"><div class="col-md-4"><label class="form-label fw-bold">Title</label><input asp-for="Title" class="form-control" required /></div><div class="col-md-3"><label class="form-label fw-bold">Category</label><select asp-for="CategoryId" class="form-select" required><option value="">Select</option>@foreach(var c in categories){<option value="@c.Id" selected="@(Model.CategoryId==c.Id)">@c.Name</option>}</select></div><div class="col-md-1"><label class="form-label fw-bold">Order</label><input asp-for="DisplayOrder" type="number" class="form-control" /></div><div class="col-md-2"><label class="form-label fw-bold">Minutes</label><input asp-for="TimeLimitMinutes" type="number" class="form-control" /></div><div class="col-md-2"><label class="form-label fw-bold">Passing %</label><input asp-for="PassingScorePercent" type="number" min="1" max="100" class="form-control" /></div><div class="col-md-12"><div class="d-flex flex-wrap gap-4"><div class="form-check"><input asp-for="IsTimed" class="form-check-input" /><label class="form-check-label">Timed</label></div><div class="form-check"><input asp-for="IsPublished" class="form-check-input" /><label class="form-check-label">Published</label></div><div class="form-check"><input asp-for="ShuffleQuestions" class="form-check-input" /><label class="form-check-label">Shuffle questions</label></div><div class="form-check"><input asp-for="ShuffleAnswers" class="form-check-input" /><label class="form-check-label">Shuffle answers</label></div><div class="form-check"><input asp-for="IsMockExam" class="form-check-input" /><label class="form-check-label">Mock exam</label></div></div></div></div><div class="my-3"><label class="form-label fw-bold">Description</label><textarea asp-for="Description" class="form-control" rows="2"></textarea></div>
<div class="border rounded p-3 mb-4 bg-light-subtle"><div class="d-flex justify-content-between align-items-center mb-2"><h5 class="mb-0">Add from Question Bank</h5><input id="bankSearch" class="form-control form-control-sm" style="max-width:320px" placeholder="Search question bank" /></div><div class="table-responsive" style="max-height:280px;overflow:auto;"><table class="table table-sm align-middle mb-0"><thead><tr><th></th><th>Question</th><th>Category</th><th>Difficulty</th><th>Topic</th></tr></thead><tbody>@foreach(var b in bankQuestions){<tr class="bank-row" data-search="@((b.Text + " " + b.Category?.Name + " " + b.Difficulty + " " + b.Topic).ToLowerInvariant())"><td><input type="checkbox" name="selectedBankQuestionIds" value="@b.Id" /></td><td>@(b.Text.Length > 110 ? b.Text[..110] + "..." : b.Text)</td><td>@b.Category?.Name</td><td>@b.Difficulty</td><td>@b.Topic</td></tr>}@if(!bankQuestions.Any()){<tr><td colspan="5" class="text-center text-muted py-3">No published bank questions available.</td></tr>}</tbody></table></div><div class="small text-muted mt-2">Checked questions are appended when you save.</div></div>
<div class="d-flex justify-content-between align-items-center mb-2"><h5 class="mb-0">Questions</h5><button type="button" class="btn btn-sm btn-outline-primary" id="addQuestion">Add Manual Question</button></div><div id="questions" class="d-grid gap-3">@for(var i=0;i<questions.Count;i++){<div class="border rounded p-3 q-row"><input type="hidden" name="Questions[@i].Order" value="@(i+1)" /><input type="hidden" name="Questions[@i].QuestionBankQuestionId" value="@questions[i].QuestionBankQuestionId" /><label class="form-label">Question</label><textarea name="Questions[@i].Text" class="form-control mb-2" rows="2">@questions[i].Text</textarea><div class="row g-2"><div class="col-md-3"><input name="Questions[@i].OptionA" value="@questions[i].OptionA" class="form-control" placeholder="A" /></div><div class="col-md-3"><input name="Questions[@i].OptionB" value="@questions[i].OptionB" class="form-control" placeholder="B" /></div><div class="col-md-3"><input name="Questions[@i].OptionC" value="@questions[i].OptionC" class="form-control" placeholder="C" /></div><div class="col-md-3"><input name="Questions[@i].OptionD" value="@questions[i].OptionD" class="form-control" placeholder="D" /></div><div class="col-md-3"><input name="Questions[@i].OptionE" value="@questions[i].OptionE" class="form-control" placeholder="E" /></div><div class="col-md-3"><input name="Questions[@i].OptionF" value="@questions[i].OptionF" class="form-control" placeholder="F" /></div></div><div class="row g-2 mt-2"><div class="col-md-2"><select name="Questions[@i].CorrectOption" class="form-select"><option selected="@(questions[i].CorrectOption=="A")">A</option><option selected="@(questions[i].CorrectOption=="B")">B</option><option selected="@(questions[i].CorrectOption=="C")">C</option><option selected="@(questions[i].CorrectOption=="D")">D</option><option selected="@(questions[i].CorrectOption=="E")">E</option><option selected="@(questions[i].CorrectOption=="F")">F</option></select></div><div class="col-md-10"><input name="Questions[@i].Explanation" value="@questions[i].Explanation" class="form-control" placeholder="Explanation" /></div></div></div>}</div><div class="admin-save-bar"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save Test</button></div></form></div></div>
<script>const bankSearch=document.getElementById('bankSearch');if(bankSearch){bankSearch.addEventListener('input',()=>{const t=bankSearch.value.toLowerCase();document.querySelectorAll('.bank-row').forEach(r=>r.style.display=r.dataset.search.includes(t)?'':'none');});}let i=document.querySelectorAll('.q-row').length;document.getElementById('addQuestion').onclick=()=>{const d=document.createElement('div');d.className='border rounded p-3 q-row';d.innerHTML=`<input type="hidden" name="Questions[${i}].Order" value="${i+1}" /><label class="form-label">Question</label><textarea name="Questions[${i}].Text" class="form-control mb-2" rows="2"></textarea><div class="row g-2"><div class="col-md-3"><input name="Questions[${i}].OptionA" class="form-control" placeholder="A" /></div><div class="col-md-3"><input name="Questions[${i}].OptionB" class="form-control" placeholder="B" /></div><div class="col-md-3"><input name="Questions[${i}].OptionC" class="form-control" placeholder="C" /></div><div class="col-md-3"><input name="Questions[${i}].OptionD" class="form-control" placeholder="D" /></div><div class="col-md-3"><input name="Questions[${i}].OptionE" class="form-control" placeholder="E" /></div><div class="col-md-3"><input name="Questions[${i}].OptionF" class="form-control" placeholder="F" /></div></div><div class="row g-2 mt-2"><div class="col-md-2"><select name="Questions[${i}].CorrectOption" class="form-select"><option>A</option><option>B</option><option>C</option><option>D</option><option>E</option><option>F</option></select></div><div class="col-md-10"><input name="Questions[${i}].Explanation" class="form-control" placeholder="Explanation" /></div></div>`;document.getElementById('questions').appendChild(d);i++;};</script>
