@{
    var featuredCourses = ViewBag.FeaturedCourses as List<DataLayer.Entities.Course> ?? new();
    var bestsellerCourses = ViewBag.BestsellerCourses as List<DataLayer.Entities.Course> ?? new();
    var categories = ViewBag.Categories as List<DataLayer.Entities.Category> ?? new();
    var testimonials = ViewBag.Testimonials as List<DataLayer.Entities.Testimonial> ?? new();
    var practiceTests = ViewBag.PracticeTests as List<DataLayer.Entities.PracticeTest> ?? new();
    var studyGuides = ViewBag.StudyGuides as List<DataLayer.Entities.StudyGuide> ?? new();
    var flashcardSets = ViewBag.FlashcardSets as List<DataLayer.Entities.FlashcardSet> ?? new();
    var faq = ViewBag.Faq as System.Collections.Generic.List<dynamic> ?? new();
    var totalCourses = (int)(ViewBag.TotalCourses ?? 0);
    var totalTests = (int)(ViewBag.TotalTests ?? 0);
    var totalGuides = (int)(ViewBag.TotalGuides ?? 0);
    var totalFlashcards = (int)(ViewBag.TotalFlashcards ?? 0);
}

<section class="premium-hero" style="padding:4rem 0 3.8rem;">
    <div class="container">
        <div class="row align-items-center gy-5">
            <div class="col-xl-7">
                <span class="section-badge"><i class="bi bi-mortarboard-fill"></i> ASVAB Exam Preparation</span>
                <h1 class="mt-3 mb-4" style="font-size:clamp(2rem,5vw,4rem);font-weight:900;line-height:1.05;max-width:780px;">Train for the ASVAB with a complete study engine, not just videos.</h1>
                <p class="mb-4" style="color:#d0d8e8;line-height:1.8;max-width:660px;font-size:1.07rem;">Practice tests, timed sections, category guides, and flashcards designed around WK, PC, AR, MK, GS, EI, MC, AS, and AO.</p>
                <div class="d-flex flex-wrap gap-3 mb-4">
                    <a href="/Courses" class="btn-primary-custom" style="padding:.95rem 1.55rem;"><i class="bi bi-arrow-right-circle"></i> Start Study Path</a>
                    <a href="/StudyPlanner" class="btn-outline-custom" style="background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.3);color:#fff;padding:.9rem 1.45rem;"><i class="bi bi-calendar-check"></i> Build Plan</a>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <span class="course-count-chip"><i class="bi bi-clipboard-check"></i> @totalCourses Courses</span>
                    <span class="course-count-chip"><i class="bi bi-pen"></i> @totalTests Practice Tests</span>
                    <span class="course-count-chip"><i class="bi bi-journal-text"></i> @totalGuides Study Guides</span>
                    <span class="course-count-chip"><i class="bi bi-stack"></i> @totalFlashcards Flashcard Sets</span>
                </div>
            </div>
            <div class="col-xl-5">
                <div class="premium-card" style="background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.2);padding:1.2rem;">
                    <div style="font-size:.76rem;text-transform:uppercase;font-weight:900;letter-spacing:.07em;color:#e2e8f0;">Student results focus</div>
                    <h2 class="mt-2" style="font-size:1.3rem;color:#fff;font-weight:900;">ASVAB readiness, tracked by category</h2>
                    <div class="mt-4 d-grid gap-3">
                        <div class="d-flex justify-content-between align-items-center"><span class="course-meta" style="color:#dbeafe;">Practice + quizzes + mock exam</span><span class="fw-bold">Adaptive scoring</span></div>
                        <div class="progress-custom"><div class="progress-bar" style="width:84%"></div></div>
                        <div class="d-flex justify-content-between align-items-center"><span class="course-meta" style="color:#dbeafe;">Personalized study roadmap</span><span class="fw-bold">Auto-generated</span></div>
                        <div class="progress-custom"><div class="progress-bar" style="width:76%"></div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="stats-bar">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-6 col-md-3 stat-item"><h3>@totalCourses</h3><p class="mb-0 course-meta">ASVAB Courses</p></div>
            <div class="col-6 col-md-3 stat-item"><h3>@categories.Count</h3><p class="mb-0 course-meta">Core Categories</p></div>
            <div class="col-6 col-md-3 stat-item"><h3>@totalTests</h3><p class="mb-0 course-meta">Practice Tests</p></div>
            <div class="col-6 col-md-3 stat-item"><h3>@totalGuides</h3><p class="mb-0 course-meta">Study Guides</p></div>
        </div>
    </div>
</section>

<section class="surface-band" style="padding:4rem 0;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3"><div><span class="section-badge"><i class="bi bi-grid"></i> ASVAB Focus Areas</span><h2 class="section-title mt-3 mb-0">Train by test category</h2></div><a href="/Categories" class="btn-outline-custom">All categories <i class="bi bi-arrow-right"></i></a></div>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
            @for (var i = 0; i < categories.Count; i++)
            {
                var category = categories[i];
                <div class="col"><a href="/Categories/Details/@category.Id" class="category-card"><div class="category-icon" style="background:@(i % 2 == 0 ? "#e7f8f6" : "#eef3ff")"><i class="bi bi-bookmark-check"></i></div><div style="font-weight:900;">@category.Name</div><div class="course-meta mt-1">@category.Courses?.Count courses</div></a></div>
            }
        </div>
    </div>
</section>

<section style="padding:4rem 0;background:#fff;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3"><div><span class="section-badge"><i class="bi bi-clipboard-check"></i> Practice Engine</span><h2 class="section-title mt-3 mb-0">ASVAB Practice Tests by category</h2></div><a href="/PracticeTests" class="btn-outline-custom">Open Practice Center <i class="bi bi-arrow-right"></i></a></div>
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @if (practiceTests.Any())
            {
                @foreach (var test in practiceTests)
                {
                    <div class="col">
                        <div class="dashboard-card h-100" style="height:100%;display:flex;flex-direction:column;">
                            <div class="d-flex align-items-center gap-2 mb-2"><span class="badge rounded-pill" style="background:#eef3ff;color:var(--brand);font-weight:900;">@test.Category.Name</span>
                                <span class="badge @(test.IsTimed ? "bg-light text-success" : "bg-light text-secondary") border">@(test.IsTimed ? "Timed" : "Untimed")</span>
                            </div>
                            <div style="font-weight:900;font-size:1.03rem;line-height:1.35;">@test.Title</div>
                            <p style="margin:0.5rem 0 1rem;color:#475467;font-size:.9rem;">@test.Description</p>
                            <div class="mt-auto d-flex justify-content-between"><span class="course-meta">@test.Questions?.Count() ?? 0 questions</span><a href="/PracticeTests/Take/@test.Id" class="btn-outline-custom" style="padding:.4rem .8rem;width:auto;">Start</a></div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12"><p class="dashboard-card mb-0 text-muted">No practice tests available yet.</p></div>
            }
        </div>
    </div>
</section>

<section class="surface-band" style="padding:4rem 0;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3"><div><span class="section-badge"><i class="bi bi-journal-text"></i> Study Resources</span><h2 class="section-title mt-3 mb-0">Guides and flashcards</h2></div><a href="/StudyGuides" class="btn-outline-custom">All study guides <i class="bi bi-arrow-right"></i></a></div>
        <div class="row g-4">
            <div class="col-lg-6">
                <h3 style="font-size:1.1rem;font-weight:900;margin-bottom:1rem;">Study Guides</h3>
                <div class="d-grid gap-3">
                    @foreach (var guide in studyGuides)
                    {
                        <a href="/StudyGuides/Read/@guide.Id" class="text-decoration-none"><div class="dashboard-card d-flex justify-content-between align-items-center gap-2"><div><strong>@guide.Title</strong><div class="course-meta mt-1">@guide.Category.Name</div></div><i class="bi bi-chevron-right"></i></div></a>
                    }
                </div>
            </div>
            <div class="col-lg-6">
                <h3 style="font-size:1.1rem;font-weight:900;margin-bottom:1rem;">Flashcard Sets</h3>
                <div class="d-grid gap-3">
                    @foreach (var set in flashcardSets)
                    {
                        <a href="/Flashcards/Study/@set.Id" class="text-decoration-none"><div class="dashboard-card d-flex justify-content-between align-items-center gap-2"><div><strong>@set.Title</strong><div class="course-meta mt-1">@set.Category.Name</div></div><i class="bi bi-chevron-right"></i></div></a>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<section style="padding:4rem 0;background:#fff;">
    <div class="container">
        <div class="text-center mb-5"><span class="section-badge"><i class="bi bi-lightning"></i> Featured Programs</span><h2 class="section-title mt-3">Courses built for every score goal</h2></div>
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4">
            @if (featuredCourses.Any())
            {
                @foreach (var course in featuredCourses)
                {
                    @await Html.PartialAsync("_CourseCard", course)
                }
            }
            else
            {
                <div class="col-12"><p class="dashboard-card mb-0 text-muted">Featured ASVAB prep courses will appear here.</p></div>
            }
        </div>
    </div>
</section>

<section style="padding:4rem 0;background:#fff;">
    <div class="container">
        <div class="text-center mb-5"><span class="section-badge"><i class="bi bi-award"></i> Most Popular</span><h2 class="section-title mt-3">Top learners are reviewing now</h2></div>
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4">
            @if (bestsellerCourses.Any())
            {
                @foreach (var course in bestsellerCourses)
                {
                    @await Html.PartialAsync("_CourseCard", course)
                }
            }
            else
            {
                <p class="dashboard-card mb-0 text-muted">Popular ASVAB prep resources will be shown here.</p>
            }
        </div>
    </div>
</section>

<section class="surface-band" style="padding:4rem 0;">
    <div class="container">
        <div class="text-center mb-5"><span class="section-badge"><i class="bi bi-chat-quote"></i> Student success</span><h2 class="section-title mt-3">What students preparing for ASVAB say</h2></div>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var testimonial in testimonials)
            {
                <div class="col"><div class="testimonial-card"><p style="color:#475467;line-height:1.75;">"@testimonial.Content"</p><div class="d-flex align-items-center gap-3 mt-3"><div style="width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--brand),var(--brand-2));display:grid;place-items:center;color:#fff;font-weight:900;">@testimonial.StudentName.Substring(0,1)</div><div><div style="font-weight:900;">@testimonial.StudentName</div><div class="course-meta">@testimonial.StudentRole</div></div></div></div></div>
            }
        </div>
    </div>
</section>

<section class="surface-band" style="padding:4rem 0;">
    <div class="container">
        <div class="text-center mb-5"><span class="section-badge"><i class="bi bi-question-circle"></i> FAQ</span><h2 class="section-title mt-3">Answers before you start</h2></div>
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="dashboard-card">
                    <div class="accordion" id="faqHome">
                        @{ var idx = 0; }
                        @foreach (var item in faq)
                        {
                            <div class="accordion-item border-0 mb-2" style="border-radius:12px;overflow:hidden;background:#f8fafc;">
                                <h2 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq@idx" aria-expanded="false" aria-controls="faq@idx">@item.Question</button></h2>
                                <div id="faq@idx" class="accordion-collapse collapse" data-bs-parent="#faqHome"><div class="accordion-body">@item.Answer</div></div>
                            </div>
                            idx++;
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section style="padding:4rem 0;background:#fff;">
    <div class="container">
        <div class="premium-hero" style="border-radius:22px;padding:3rem 2rem;text-align:center;box-shadow:var(--shadow-lg);">
            <span class="section-badge"><i class="bi bi-rocket-takeoff"></i> Begin your ASVAB run</span>
            <h2 class="section-title text-white mt-3 mb-3">Stop preparing blind. Prepare with signals.</h2>
            <p style="color:#d0d8e8;max-width:580px;margin:0 auto 1.4rem;line-height:1.8;">Get practice, guidance, and plan updates based on your performance after every attempt.</p>
            <a href="/Courses" class="btn-primary-custom" style="background:#fff;color:var(--brand);box-shadow:none;">Start Preparation</a>
        </div>
    </div>
</section>
