@model DataLayer.Entities.Lesson
@{
    ViewData["Title"] = "Edit Lesson";
    var courseId = (Guid)ViewBag.CourseId;
    var courseTitle = ViewBag.CourseTitle as string ?? "Course";
}
<div class="d-flex justify-content-between align-items-center mb-4"><div><h2>Edit Lesson</h2><p class="text-muted mb-0">@courseTitle</p></div><a href="/Lessons/Index/@courseId" class="btn btn-outline-secondary">Back</a></div>
<div class="card shadow-sm border-0"><div class="card-body">
<form method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="SectionId" />
    <input type="hidden" asp-for="Order" />
    <input type="hidden" asp-for="ContentUrl" />
    <input type="hidden" asp-for="ResourcesUrl" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-8"><label class="form-label fw-bold">Title</label><input asp-for="Title" class="form-control" required maxlength="200" /></div>
        <div class="col-md-4"><label class="form-label fw-bold">Type</label><select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<SharedLayer.Enums.LessonType>()"></select></div>
        <div class="col-md-4"><label class="form-label fw-bold">Duration Minutes</label><input asp-for="DurationMinutes" type="number" min="0" class="form-control" /></div>
        <div class="col-md-8"><label class="form-label fw-bold">Video URL</label><input asp-for="ContentUrl" class="form-control" /></div>
        <div class="col-md-6"><label class="form-label fw-bold">Replace Video</label><input name="videoFile" type="file" accept="video/mp4,video/webm,video/quicktime" class="form-control" /><div class="form-text">Current: @(Model.ContentUrl ?? "none")</div></div>
        <div class="col-md-6"><label class="form-label fw-bold">Replace PDF Resource</label><input name="pdfFile" type="file" accept="application/pdf" class="form-control" /><div class="form-check mt-2"><input name="deletePdf" value="true" class="form-check-input" type="checkbox" /><label class="form-check-label">Delete current PDF</label></div><div class="form-text">Current: @(Model.ResourcesUrl ?? "none")</div></div>
        <div class="col-12"><label class="form-label fw-bold">Description</label><textarea asp-for="Description" class="form-control" rows="2"></textarea></div>
        <div class="col-12"><label class="form-label fw-bold">Article Content</label><textarea asp-for="ArticleContent" class="form-control" rows="5"></textarea></div>
        <div class="col-md-8"><label class="form-label fw-bold">External Resource URL</label><input asp-for="ResourcesUrl" class="form-control" /></div>
        <div class="col-md-2 form-check mt-5"><input asp-for="IsFreePreview" class="form-check-input" /><label class="form-check-label">Free preview</label></div>
        <div class="col-md-2 form-check mt-5"><input asp-for="IsPublished" class="form-check-input" /><label class="form-check-label">Published</label></div>
    </div>
    <button type="submit" class="btn btn-primary mt-4"><i class="bi bi-save me-1"></i> Save Lesson</button>
</form></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }


