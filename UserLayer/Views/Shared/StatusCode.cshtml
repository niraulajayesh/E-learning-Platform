@model int
@{
    var title = Model == 403 ? "Access denied" : Model == 404 ? "Page not found" : "Something went wrong";
    var message = Model == 403 ? "You do not have permission to view this page." : Model == 404 ? "The page you requested does not exist or has moved." : "The request could not be completed.";
    ViewData["Title"] = title;
}

<section class="container py-5">
    <div class="dashboard-card text-center mx-auto" style="max-width:720px;">
        <span class="section-badge"><i class="bi bi-shield-lock"></i> @Model</span>
        <h1 class="section-title mt-3 mb-3">@title</h1>
        <p class="text-muted" style="line-height:1.7;">@message</p>
        <div class="d-flex justify-content-center gap-2 flex-wrap mt-4">
            <a href="/" class="btn-primary-custom">Home</a>
            <a href="/Courses" class="btn-outline-custom">Browse courses</a>
        </div>
    </div>
</section>