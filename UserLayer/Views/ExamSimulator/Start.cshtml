@model List<DataLayer.Entities.QuestionBankQuestion>
@{
    var groups = Model.GroupBy(q => q.Category.Name).OrderBy(g => g.Key).ToList();
    var sectionMinutes = ViewBag.SectionMinutes as Dictionary<string,int> ?? new();
    var totalMinutes = (int)(ViewBag.TotalMinutes ?? 0);
}
<section class="premium-hero py-4"><div class="container"><span class="section-badge"><i class="bi bi-stopwatch"></i> Mock Exam</span><h1 class="section-title text-white mt-3 mb-2">Full-Length ASVAB Mock Exam</h1><p style="color:#cbd5e1">@Model.Count questions · @totalMinutes minutes · All ASVAB categories</p></div></section>
<div class="container py-5"><form method="post" action="/ExamSimulator/Submit" id="examForm">@Html.AntiForgeryToken()<div class="d-flex justify-content-between align-items-center mb-4 sticky-top bg-white border rounded p-3" style="top:84px;z-index:10"><strong>Exam in progress</strong><span class="course-count-chip"><i class="bi bi-stopwatch"></i><span id="timer">@totalMinutes:00</span></span></div>@foreach(var group in groups){var code=group.Key.Split(' ')[0];<section class="dashboard-card mb-4"><div class="d-flex justify-content-between align-items-center mb-3"><h2 style="font-size:1.4rem">@group.Key</h2><span class="badge bg-primary">@(sectionMinutes.TryGetValue(code, out var mins) ? mins : 8) min section</span></div>@foreach(var q in group){<div class="border-top pt-3 mt-3"><div class="fw-bold mb-3">@q.DisplayOrder. @q.Text</div>@foreach(var opt in new[]{("A",q.OptionA),("B",q.OptionB),("C",q.OptionC),("D",q.OptionD)}){<label class="d-flex gap-2 align-items-start border rounded p-3 mb-2"><input type="radio" name="answers[@q.Id]" value="@opt.Item1" class="form-check-input mt-1" /><span><strong>@opt.Item1.</strong> @opt.Item2</span></label>}</div>}</section>}<button class="btn-primary-custom" style="border:none;">Submit Exam</button></form></div>
<script>let s=@(totalMinutes*60);const t=document.getElementById('timer'),f=document.getElementById('examForm');setInterval(()=>{if(s<=0){f.submit();return;}s--;const m=Math.floor(s/60),r=String(s%60).padStart(2,'0');t.textContent=`${m}:${r}`;},1000);</script>
