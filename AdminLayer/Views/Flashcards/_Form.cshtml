@model DataLayer.Entities.FlashcardSet
@{
    var categories = ViewData["Categories"] as List<DataLayer.Entities.Category> ?? new();
    var cards = Model.Cards?.OrderBy(c => c.Order).ToList() ?? new List<DataLayer.Entities.Flashcard>();
}
<div class="card shadow-sm border-0"><div class="card-body"><form method="post">@Html.AntiForgeryToken()<div asp-validation-summary="All" class="text-danger admin-form-alert mb-3"></div><div class="row"><div class="col-md-6 mb-3"><label class="form-label fw-bold">Title</label><input asp-for="Title" class="form-control" required /></div><div class="col-md-4 mb-3"><label class="form-label fw-bold">Category</label><select asp-for="CategoryId" class="form-select" required><option value="">Select category</option>@foreach(var c in categories){<option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option>}</select></div><div class="col-md-2 mb-3 d-flex align-items-end"><div class="form-check"><input asp-for="IsPublished" class="form-check-input" /><label asp-for="IsPublished" class="form-check-label">Published</label></div></div></div><div class="mb-3"><label class="form-label fw-bold">Description</label><textarea asp-for="Description" class="form-control" rows="2"></textarea></div><div class="d-flex justify-content-between align-items-center mb-2"><h5 class="mb-0">Cards</h5><button type="button" class="btn btn-sm btn-outline-primary" id="addCard"><i class="bi bi-plus-lg"></i> Add Card</button></div><div id="cards" class="d-grid gap-3">@for(var i=0;i<cards.Count;i++){<div class="border rounded p-3 card-row"><input type="hidden" name="Cards[@i].Order" value="@(i+1)" /><div class="row"><div class="col-md-5 mb-2"><label class="form-label">Front</label><textarea name="Cards[@i].Front" class="form-control" rows="2">@cards[i].Front</textarea></div><div class="col-md-5 mb-2"><label class="form-label">Back</label><textarea name="Cards[@i].Back" class="form-control" rows="2">@cards[i].Back</textarea></div><div class="col-md-2 mb-2"><label class="form-label">Hint</label><input name="Cards[@i].Hint" value="@cards[i].Hint" class="form-control" /></div></div></div>}</div><div class="admin-save-bar"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save Set</button></div></form></div></div>
<script>let index=document.querySelectorAll('.card-row').length;document.getElementById('addCard').addEventListener('click',()=>{const div=document.createElement('div');div.className='border rounded p-3 card-row';div.innerHTML=`<input type="hidden" name="Cards[${index}].Order" value="${index+1}" /><div class="row"><div class="col-md-5 mb-2"><label class="form-label">Front</label><textarea name="Cards[${index}].Front" class="form-control" rows="2"></textarea></div><div class="col-md-5 mb-2"><label class="form-label">Back</label><textarea name="Cards[${index}].Back" class="form-control" rows="2"></textarea></div><div class="col-md-2 mb-2"><label class="form-label">Hint</label><input name="Cards[${index}].Hint" class="form-control" /></div></div>`;document.getElementById('cards').appendChild(div);index++;});</script>
