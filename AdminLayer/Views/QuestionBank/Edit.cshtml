@model DataLayer.Entities.QuestionBankQuestion
<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 mb-1">Edit Question</h1><p class="text-muted mb-0">Update metadata, answer choices, explanation, and status.</p></div>
    <div class="d-flex gap-2"><a class="btn btn-outline-secondary" asp-action="Preview" asp-route-id="@Model.Id"><i class="bi bi-eye"></i> Preview</a><a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left"></i> Back</a></div>
</div>
<div class="card border-0 shadow-sm"><div class="card-body">
<form asp-action="Edit" asp-route-id="@Model.Id" method="post">@Html.AntiForgeryToken()<partial name="_QuestionForm" model="Model" /><div class="admin-save-bar"><button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> Save Changes</button><a class="btn btn-outline-secondary" asp-action="Index">Cancel</a></div></form>
</div></div>

