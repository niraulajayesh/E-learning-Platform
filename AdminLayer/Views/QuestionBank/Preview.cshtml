@model DataLayer.Entities.QuestionBankQuestion
@{
    var options = new[] { ("A", Model.OptionA), ("B", Model.OptionB), ("C", Model.OptionC), ("D", Model.OptionD), ("E", Model.OptionE), ("F", Model.OptionF) }.Where(o => !string.IsNullOrWhiteSpace(o.Item2)).ToList();
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h1 class="h3 mb-1">Question Preview</h1><p class="text-muted mb-0">@Model.Category?.Name · @Model.Topic · @Model.Difficulty</p></div>
    <div class="d-flex gap-2"><a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id"><i class="bi bi-pencil"></i> Edit</a><a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left"></i> Back</a></div>
</div>
<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm"><div class="card-body p-4">
            <div class="d-flex flex-wrap gap-2 mb-3"><span class="badge bg-info-subtle text-info border border-info-subtle">@Model.Difficulty</span><span class="badge @(Model.Status == "Published" ? "bg-success" : Model.Status == "Archived" ? "bg-secondary" : "bg-warning text-dark")">@Model.Status</span><span class="badge bg-light text-dark border">@Model.EstimatedTimeSeconds sec</span></div>
            <h2 class="h5 mb-3">@Model.Text</h2>
            @if (!string.IsNullOrWhiteSpace(Model.QuestionImageUrl)) { <img src="@Model.QuestionImageUrl" class="img-fluid rounded border mb-3" alt="Question image" /> }
            <div class="d-grid gap-2 mb-4">
                @foreach (var option in options)
                {
                    <div class="border rounded p-3 @(option.Item1 == Model.CorrectOption ? "border-success bg-success-subtle" : "")"><strong>@option.Item1.</strong> @option.Item2</div>
                }
            </div>
            <h3 class="h6">Detailed Explanation</h3>
            <p>@Model.Explanation</p>
            @if (!string.IsNullOrWhiteSpace(Model.ExplanationImageUrl)) { <img src="@Model.ExplanationImageUrl" class="img-fluid rounded border mb-3" alt="Explanation image" /> }
            @if (!string.IsNullOrWhiteSpace(Model.WrongAnswerExplanation)) { <h3 class="h6">Wrong Answer Notes</h3><p class="text-muted">@Model.WrongAnswerExplanation</p> }
        </div></div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm"><div class="card-body">
            <h3 class="h6">Metadata</h3>
            <dl class="mb-0">
                <dt>Subtopic</dt><dd>@Model.Subtopic</dd>
                <dt>Tags</dt><dd>@Model.Tags</dd>
                <dt>Source</dt><dd>@Model.SourceReference</dd>
                <dt>Used in practice tests</dt><dd>@Model.PracticeTestQuestions.Count</dd>
                <dt>Created</dt><dd>@Model.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy h:mm tt") by @(Model.CreatedBy ?? "n/a")</dd>
                <dt>Modified</dt><dd>@Model.UpdatedAt.ToLocalTime().ToString("MMM dd, yyyy h:mm tt") by @(Model.ModifiedBy ?? "n/a")</dd>
            </dl>
        </div></div>
    </div>
</div>
