@model ErrorViewModel
@{
    ViewData["Title"] = "Something went wrong";
}

<div class="card shadow-sm border-0 mx-auto" style="max-width:720px;">
    <div class="card-body text-center p-5">
        <span class="badge text-bg-danger mb-3">Error</span>
        <h1 class="h3 fw-bold mb-3">We could not complete that request.</h1>
        <p class="text-muted">The admin portal logged the issue. Please return to the dashboard or try again.</p>
        @if (Model.ShowRequestId)
        {
            <p class="small text-muted">Request ID: <code>@Model.RequestId</code></p>
        }
        <a href="/Home" class="btn btn-primary mt-3">Admin dashboard</a>
    </div>
</div>