@model DataLayer.Entities.Testimonial
@{
    ViewData["Title"] = "Add Testimonial";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Add Testimonial</h2>
    <a asp-controller="Testimonials" asp-action="Index" class="btn btn-outline-secondary">Back to Testimonials</a>
</div>

<div class="card shadow-sm border-0" style="max-width: 760px;">
    <div class="card-body">
        <form method="post" asp-controller="Testimonials" asp-action="Create">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="StudentName" class="form-label fw-bold">Student Name</label>
                    <input asp-for="StudentName" class="form-control" maxlength="100" required />
                    <span asp-validation-for="StudentName" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="StudentRole" class="form-label fw-bold">Student Role</label>
                    <input asp-for="StudentRole" class="form-control" maxlength="100" />
                    <span asp-validation-for="StudentRole" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="ProfilePictureUrl" class="form-label fw-bold">Profile Picture URL</label>
                <input asp-for="ProfilePictureUrl" class="form-control" maxlength="500" />
                <span asp-validation-for="ProfilePictureUrl" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Content" class="form-label fw-bold">Testimonial</label>
                <textarea asp-for="Content" class="form-control" rows="5" maxlength="1000" required></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>

            <div class="row align-items-end">
                <div class="col-md-4 mb-3">
                    <label asp-for="Rating" class="form-label fw-bold">Rating</label>
                    <input asp-for="Rating" type="number" min="1" max="5" class="form-control" />
                    <span asp-validation-for="Rating" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="DisplayOrder" class="form-label fw-bold">Display Order</label>
                    <input asp-for="DisplayOrder" type="number" class="form-control" />
                    <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3 form-check">
                    <input asp-for="IsVisible" class="form-check-input" />
                    <label asp-for="IsVisible" class="form-check-label fw-bold">Visible</label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Create Testimonial</button>
        </form>
    </div>
</div>
