@model DataLayer.Entities.Course
@{
    var displayPrice = Model.DiscountedPrice ?? Model.Price;
    var levelBadge = Model.Level switch {
        SharedLayer.Enums.CourseLevel.Beginner => ("badge-beginner", "Beginner"),
        SharedLayer.Enums.CourseLevel.Intermediate => ("badge-intermediate", "Intermediate"),
        SharedLayer.Enums.CourseLevel.Advanced => ("badge-advanced", "Advanced"),
        _ => ("badge-all", "All Levels")
    };
    var imageUrl = string.IsNullOrWhiteSpace(Model.ThumbnailUrl) ? null : Model.ThumbnailUrl;
    var duration = Model.TotalDurationMinutes > 0 ? $"{Model.TotalDurationMinutes / 60}h {Model.TotalDurationMinutes % 60}m" : "Self paced";
}

<div class="col">
    <a href="/Courses/Details/@Model.Id" class="text-decoration-none" aria-label="View @Model.Title">
        <article class="course-card h-100 d-flex flex-column">
            <div class="course-media">
                @if (!string.IsNullOrEmpty(imageUrl))
                {
                    <img src="@imageUrl" alt="@Model.Title" />
                }
                else
                {
                    <div class="course-media-fallback"><i class="bi bi-journal-code"></i></div>
                }

                <div class="position-absolute start-0 top-0 w-100 px-3 pt-3 d-flex align-items-start justify-content-between">
                    <span class="badge-level @levelBadge.Item1">@levelBadge.Item2</span>
                    @if (Model.IsBestseller)
                    {
                        <span class="badge rounded-pill" style="background:#fff;color:#b54708;font-weight:900;box-shadow:var(--shadow-sm);">Bestseller</span>
                    }
                </div>
            </div>

            <div class="card-body p-3 p-sm-4">
                <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                    <span class="course-meta"><i class="bi bi-clock me-1"></i>@duration</span>
                    <span class="course-meta"><i class="bi bi-people me-1"></i>@Model.TotalEnrollments</span>
                </div>

                <h3 class="course-title mb-2">@Model.Title</h3>

                @if (Model.Instructor != null)
                {
                    <p class="course-meta mb-2"><i class="bi bi-person-workspace me-1"></i>@Model.Instructor.FullName</p>
                }

                <div class="d-flex align-items-center gap-1 mb-3">
                    <span style="color:var(--brand-3);font-weight:900;font-size:.88rem;">@Model.AverageRating.ToString("0.0")</span>
                    <span class="rating-stars" aria-hidden="true">
                        @for (var i = 1; i <= 5; i++)
                        {
                            <i class="bi @(i <= (int)Math.Round(Model.AverageRating) ? "bi-star-fill" : "bi-star")"></i>
                        }
                    </span>
                    <span class="course-meta">(@Model.TotalReviews)</span>
                </div>

                <div class="d-flex align-items-center justify-content-between gap-3 pt-3 border-top">
                    <div>
                        @if (displayPrice == 0)
                        {
                            <span class="course-price course-price-free">Free</span>
                        }
                        else
                        {
                            <span class="course-price">$@displayPrice.ToString("0.00")</span>
                            @if (Model.DiscountedPrice.HasValue)
                            {
                                <span class="course-old-price ms-2">$@Model.Price.ToString("0.00")</span>
                            }
                        }
                    </div>
                    <span class="badge rounded-pill bg-light text-primary border">Course</span>
                </div>
            </div>
        </article>
    </a>
</div>
