@using SharedLayer.Enums
@model DataLayer.Entities.User
@{
    ViewData["Title"] = "Edit User";
}
<div class="d-flex justify-content-between align-items-center mb-4"><h2>Edit User</h2><a href="/Users" class="btn btn-outline-secondary">Back to List</a></div>
<div class="row g-4"><div class="col-lg-7"><div class="card shadow-sm border-0"><div class="card-body"><form method="post">@Html.AntiForgeryToken()<input type="hidden" asp-for="Id" /><input type="hidden" asp-for="Email" /><div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div><div class="mb-3"><label class="form-label fw-bold">Email</label><input type="email" class="form-control" value="@Model.Email" disabled /></div><div class="row"><div class="col-md-6 mb-3"><label asp-for="FirstName" class="form-label fw-bold">First Name</label><input asp-for="FirstName" class="form-control" required /></div><div class="col-md-6 mb-3"><label asp-for="LastName" class="form-label fw-bold">Last Name</label><input asp-for="LastName" class="form-control" required /></div></div><div class="mb-3"><label asp-for="Role" class="form-label fw-bold">Role</label><select asp-for="Role" class="form-select" asp-items="Html.GetEnumSelectList<UserRole>()"></select></div><div class="mb-3"><label asp-for="Headline" class="form-label fw-bold">Headline</label><input asp-for="Headline" class="form-control" /></div><div class="mb-3"><label asp-for="Bio" class="form-label fw-bold">Bio</label><textarea asp-for="Bio" class="form-control" rows="4"></textarea></div><div class="row"><div class="col-md-6 mb-3"><label asp-for="WebsiteUrl" class="form-label fw-bold">Website</label><input asp-for="WebsiteUrl" class="form-control" /></div><div class="col-md-6 mb-3"><label asp-for="LinkedInUrl" class="form-label fw-bold">LinkedIn</label><input asp-for="LinkedInUrl" class="form-control" /></div></div><input type="hidden" asp-for="IsActive" /><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save Changes</button></form></div></div></div><div class="col-lg-5"><div class="card shadow-sm border-0"><div class="card-body"><h5>Password Reset</h5><form asp-action="ResetPassword" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><label class="form-label">New Password</label><input name="newPassword" type="password" minlength="6" class="form-control" required /><button class="btn btn-outline-danger mt-3">Reset Password</button></form></div></div><div class="card shadow-sm border-0 mt-3"><div class="card-body"><h5>Learning Records</h5><p class="mb-1">Enrollments: @Model.Enrollments.Count</p><p class="mb-0">Quiz Attempts: @Model.QuizAttempts.Count</p></div></div></div></div>


