@{
    var category = ViewBag.Category as DataLayer.Entities.Category;
    var courses   = ViewBag.Courses  as List<DataLayer.Entities.Course> ?? new();
}

<div class="hero-dark py-5">
    <div class="container">
        <nav style="font-size:0.82rem;margin-bottom:1rem;">
            <a href="/" style="color:#9ca3af;text-decoration:none;">Home</a>
            <span style="color:#6b7280;margin:0 0.4rem;">/</span>
            <a href="/Categories" style="color:#9ca3af;text-decoration:none;">Categories</a>
            <span style="color:#6b7280;margin:0 0.4rem;">/</span>
            <span style="color:#e9d5ff;">@category?.Name</span>
        </nav>
        <h1 class="section-title text-white">@category?.Name</h1>
        @if (!string.IsNullOrEmpty(category?.Description))
        {
            <p style="color:#c4b5fd;max-width:600px;">@category.Description</p>
        }
        <p style="color:#9ca3af;font-size:0.9rem;"><strong style="color:#e9d5ff;">@courses.Count</strong> courses available</p>
    </div>
</div>

<div class="container py-5">
    @if (courses.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var course in courses)
            {
                @await Html.PartialAsync("_CourseCard", course)
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-collection" style="font-size:4rem;color:#d8b4fe;"></i>
            <h4 class="mt-3">No courses in this category yet</h4>
            <a href="/Courses" class="btn-primary-custom mt-3">Browse All Courses</a>
        </div>
    }
</div>
