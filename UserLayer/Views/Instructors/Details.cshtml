@model UserLayer.Models.InstructorProfileViewModel
@{
    var instructor = Model.Instructor;
    var courses = Model.Courses;
}

<div class="hero-dark" style="padding:3.25rem 0;">
    <div class="container">
        <div class="row align-items-center gy-4">
            <div class="col-auto">
                @if (!string.IsNullOrEmpty(instructor.ProfilePictureUrl))
                {
                    <img src="@instructor.ProfilePictureUrl" alt="@instructor.FullName" class="instructor-avatar" style="width:104px;height:104px;border:4px solid rgba(196,181,253,0.4);" />
                }
                else
                {
                    <div style="width:104px;height:104px;border-radius:50%;background:linear-gradient(135deg,#6c2bd9,#8b5cf6);display:flex;align-items:center;justify-content:center;color:#fff;font-size:2.4rem;font-weight:800;border:4px solid rgba(196,181,253,0.4);">@instructor.FirstName.Substring(0,1)</div>
                }
            </div>
            <div class="col">
                <span class="section-badge">Instructor profile</span>
                <h1 class="section-title text-white mb-1">@instructor.FullName</h1>
                @if (!string.IsNullOrEmpty(instructor.Headline))
                {
                    <p style="color:#c4b5fd;font-size:1rem;margin-bottom:0.8rem;">@instructor.Headline</p>
                }
                <div class="d-flex gap-3 flex-wrap" style="font-size:0.86rem;color:#9ca3af;">
                    <span><i class="bi bi-book me-1"></i><strong style="color:#e9d5ff;">@courses.Count</strong> courses</span>
                    <span><i class="bi bi-people me-1"></i><strong style="color:#e9d5ff;">@Model.TotalStudents</strong> students</span>
                    <span><i class="bi bi-star-fill me-1"></i><strong style="color:#e9d5ff;">@Model.AverageRating.ToString("0.0")</strong> rating</span>
                </div>
                <div class="d-flex gap-3 mt-3 flex-wrap">
                    @if (!string.IsNullOrEmpty(instructor.WebsiteUrl))
                    {
                        <a href="@instructor.WebsiteUrl" target="_blank" rel="noopener" style="color:#c4b5fd;font-size:0.86rem;text-decoration:none;"><i class="bi bi-globe me-1"></i>Website</a>
                    }
                    @if (!string.IsNullOrEmpty(instructor.LinkedInUrl))
                    {
                        <a href="@instructor.LinkedInUrl" target="_blank" rel="noopener" style="color:#c4b5fd;font-size:0.86rem;text-decoration:none;"><i class="bi bi-linkedin me-1"></i>LinkedIn</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <section class="dashboard-card mb-4">
                <h2 style="font-weight:800;font-size:1.2rem;margin-bottom:1rem;">About @instructor.FirstName</h2>
                @if (!string.IsNullOrEmpty(instructor.Bio))
                {
                    <p style="color:#4b5563;line-height:1.85;font-size:0.95rem;margin:0;">@instructor.Bio</p>
                }
                else
                {
                    <p class="text-muted mb-0">@instructor.FirstName has not added a bio yet.</p>
                }
            </section>
            <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-2">
                <div><span class="section-badge">Published courses</span><h2 class="section-title mb-0" style="font-size:1.55rem;">Courses by <span class="text-gradient">@instructor.FirstName</span></h2></div>
                <a href="/Courses" class="btn-outline-custom">Browse Catalog</a>
            </div>
            @if (courses.Any())
            {
                <div class="row row-cols-1 row-cols-md-2 g-4">
                    @foreach (var course in courses)
                    {
                        @await Html.PartialAsync("_CourseCard", course)
                    }
                </div>
            }
            else
            {
                <div class="dashboard-card text-center py-5"><i class="bi bi-book" style="font-size:3rem;color:#d8b4fe;"></i><h3 style="font-size:1.15rem;font-weight:800;margin-top:1rem;">No published courses</h3><p class="text-muted mb-0">This instructor does not have published courses available yet.</p></div>
            }
        </div>
        <aside class="col-lg-4">
            <section class="dashboard-card">
                <h2 style="font-weight:800;font-size:1.1rem;margin-bottom:1rem;">Teaching snapshot</h2>
                <div class="d-grid gap-3">
                    <div class="d-flex justify-content-between"><span class="text-muted">Courses</span><strong>@courses.Count</strong></div>
                    <div class="d-flex justify-content-between"><span class="text-muted">Students</span><strong>@Model.TotalStudents</strong></div>
                    <div class="d-flex justify-content-between"><span class="text-muted">Average rating</span><strong>@Model.AverageRating.ToString("0.0")</strong></div>
                </div>
            </section>
        </aside>
    </div>
</div>
