@model ErrorViewModel
@{
    ViewData["Title"] = "Something went wrong";
}

<section class="container py-5">
    <div class="dashboard-card text-center mx-auto" style="max-width:720px;">
        <span class="section-badge"><i class="bi bi-exclamation-triangle"></i> Error</span>
        <h1 class="section-title mt-3 mb-3">We could not complete that request.</h1>
        <p class="text-muted" style="line-height:1.7;">The platform logged the issue. Please return to your dashboard or try again in a moment.</p>
        @if (Model.ShowRequestId)
        {
            <p class="small text-muted">Request ID: <code>@Model.RequestId</code></p>
        }
        <div class="d-flex justify-content-center gap-2 flex-wrap mt-4">
            <a href="/Dashboard" class="btn-primary-custom">Dashboard</a>
            <a href="/" class="btn-outline-custom">Home</a>
        </div>
    </div>
</section>